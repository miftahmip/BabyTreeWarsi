<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login-BabyTree</title>
  <link href="/output.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --green-deep:   #1a4731;
      --green-mid:    #2d6a4f;
      --green-bright: #40916c;
      --green-light:  #74c69d;
      --green-pale:   #d8f3dc;
      --brown-mid:    #7d5a3c;
      --brown-dark:   #5c3d1e;
      --cream:        #fdf8f0;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background:
        radial-gradient(ellipse 80% 60% at 15% 10%, #b7e4c7 0%, transparent 55%),
        radial-gradient(ellipse 60% 50% at 85% 85%, rgba(160,118,90,0.15) 0%, transparent 55%),
        radial-gradient(ellipse 50% 70% at 70% 5%,  #d8f3dc 0%, transparent 50%),
        var(--cream);
      overflow: hidden;
      position: relative;
    }

    /* Leaf decorations */
    .leaf { position: fixed; opacity: .13; pointer-events: none; z-index: 0; }
    .leaf-1 { top: -60px;   left: -60px;  width: 320px; transform: rotate(-20deg);  }
    .leaf-2 { bottom: -80px; right: -80px; width: 400px; transform: rotate(160deg); }
    .leaf-3 { top: 42%;    left: -35px;  width: 190px; transform: rotate(30deg);   }
    .leaf-4 { top: 8%;     right: -20px; width: 170px; transform: rotate(-45deg);  }

    /* Card */
    .card {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 400px;        /* ← lebar dibatasi */
      margin: 1rem;
      padding: 44px 40px 40px;
      background: rgba(255,255,255,0.78);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border: 1px solid rgba(116,198,157,0.28);
      border-radius: 24px;
      box-shadow: 0 8px 40px rgba(26,71,49,0.16), 0 1px 0 rgba(255,255,255,0.9) inset;
      animation: riseUp .65s cubic-bezier(.22,1,.36,1) both;
    }
    @keyframes riseUp {
      from { opacity:0; transform: translateY(28px) scale(.97); }
      to   { opacity:1; transform: translateY(0)    scale(1);   }
    }

    /* Icon badge */
    .icon-badge {
      width: 60px; height: 60px;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--green-bright), var(--green-deep));
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 24px;
      box-shadow: 0 6px 18px rgba(45,106,79,.32);
      animation: badgePop .5s .25s cubic-bezier(.34,1.56,.64,1) both;
    }
    @keyframes badgePop {
      from { transform: scale(0.5) rotate(-10deg); opacity:0; }
      to   { transform: scale(1)   rotate(0deg);   opacity:1; }
    }

    /* Typography */
    .card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--green-deep);
      text-align: center;
      letter-spacing: -.4px;
      line-height: 1.2;
      margin: 0 0 6px;
    }
    .card-subtitle {
      font-size: .84rem;
      color: var(--brown-mid);
      text-align: center;
      font-weight: 300;
      margin: 0 0 30px;
    }

    /* Labels */
    .field-label {
      display: block;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .9px;
      text-transform: uppercase;
      color: var(--green-deep);
      margin-bottom: 7px;
    }

    /* Input wrapper */
    .input-wrap {
      position: relative;
      margin-bottom: 18px;
    }
    .input-wrap .ico-left {
      position: absolute;
      left: 13px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--green-bright);
      pointer-events: none;
      display: flex;
      align-items: center;
    }
    .input-wrap input {
      width: 100%;
      padding: 12px 13px 12px 40px;   /* left room for icon */
      border-radius: 11px;
      border: 1.5px solid rgba(116,198,157,.42);
      background: rgba(216,243,220,.18);
      font-family: 'DM Sans', sans-serif;
      font-size: .92rem;
      color: var(--green-deep);
      outline: none;
      box-sizing: border-box;
      transition: border-color .2s, box-shadow .2s, background .2s;
    }
    .input-wrap input::placeholder { color: #aac8b4; }
    .input-wrap input:focus {
      border-color: var(--green-bright);
      background: rgba(216,243,220,.40);
      box-shadow: 0 0 0 3px rgba(64,145,108,.12);
    }

    /* Password field — extra right padding for eye button */
    #password {
      padding-right: 42px;
    }

    /* Eye toggle — ONLY inside password wrapper */
    .eye-btn {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: #aac8b4;
      display: flex;
      align-items: center;
      padding: 0;
      line-height: 1;
      transition: color .2s;
    }
    .eye-btn:hover { color: var(--green-bright); }

    /* Forgot password row */
    .pw-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 7px;
    }
    .pw-header a {
      font-size: .72rem;
      font-weight: 500;
      color: var(--brown-mid);
      text-decoration: none;
      transition: color .2s;
    }
    .pw-header a:hover { color: var(--brown-dark); }

    /* Submit */
    .btn-login {
      display: block;
      width: 100%;
      padding: 13px;
      margin-top: 10px;
      border: none;
      border-radius: 13px;
      background: linear-gradient(135deg, var(--green-bright) 0%, var(--green-deep) 100%);
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: .97rem;
      font-weight: 600;
      letter-spacing: .3px;
      cursor: pointer;
      box-shadow: 0 5px 18px rgba(45,106,79,.38);
      transition: transform .18s, box-shadow .18s;
    }
    .btn-login:hover  { transform: translateY(-2px); box-shadow: 0 9px 26px rgba(45,106,79,.46); }
    .btn-login:active { transform: translateY(0);    box-shadow: 0 3px 10px rgba(45,106,79,.32); }

    /* Divider */
    .divider {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 24px 0 20px;
      font-size: .72rem;
      letter-spacing: .6px;
      color: #b5cfbb;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(116,198,157,.35), transparent);
    }

    /* Register */
    .register-row {
      text-align: center;
      font-size: .84rem;
      color: var(--brown-mid);
    }
    .register-row a {
      font-weight: 600;
      color: var(--green-bright);
      text-decoration: none;
      transition: color .2s;
    }
    .register-row a:hover { color: var(--green-deep); }

    /* Error alert */
    .alert-error {
      display: flex;
      align-items: center;
      gap: 8px;
      background: #fff0f0;
      border: 1px solid #f5c6c6;
      color: #b03030;
      border-radius: 10px;
      padding: 10px 13px;
      font-size: .83rem;
      margin-bottom: 18px;
    }

    /* Particles */
    .particle {
      position: fixed;
      pointer-events: none;
      z-index: 1;
      animation: floatUp linear infinite;
      opacity: 0;
    }
    @keyframes floatUp {
      0%   { transform: translateY(110vh) rotate(0deg);   opacity: 0;  }
      5%   { opacity: .45; }
      95%  { opacity: .45; }
      100% { transform: translateY(-10vh) rotate(360deg); opacity: 0;  }
    }


    /* Shake animation saat error */
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      15%       { transform: translateX(-6px); }
      30%       { transform: translateX(6px); }
      45%       { transform: translateX(-4px); }
      60%       { transform: translateX(4px); }
      75%       { transform: translateX(-2px); }
      90%       { transform: translateX(2px); }
    }
    .shake {
      animation: shake .45s cubic-bezier(.36,.07,.19,.97) both;
    }

    /* Alert error lebih informatif */
    .alert-error {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      background: #fff5f5;
      border: 1px solid #fca5a5;
      color: #b91c1c;
      border-radius: 12px;
      padding: 12px 14px;
      font-size: .83rem;
      margin-bottom: 20px;
      animation: shake .45s cubic-bezier(.36,.07,.19,.97) both;
    }
    .alert-error-icon {
      flex-shrink: 0;
      width: 32px; height: 32px;
      border-radius: 8px;
      background: #fee2e2;
      display: flex; align-items: center; justify-content: center;
      color: #b91c1c;
    }
    .alert-error-body .alert-title {
      font-weight: 600;
      font-size: .83rem;
      color: #b91c1c;
      margin-bottom: 2px;
    }
    .alert-error-body .alert-msg {
      font-size: .78rem;
      color: #c55;
      font-weight: 400;
    }
  </style>
</head>
<body>

  <!-- Leaf SVGs -->
  <svg class="leaf leaf-1" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M100 180 C20 140 10 60 100 20 C190 60 180 140 100 180Z" fill="#2d6a4f"/>
    <line x1="100" y1="20" x2="100" y2="180" stroke="#1a4731" stroke-width="2"/>
    <line x1="100" y1="80"  x2="60"  y2="60"  stroke="#1a4731" stroke-width="1.2"/>
    <line x1="100" y1="100" x2="140" y2="80"  stroke="#1a4731" stroke-width="1.2"/>
    <line x1="100" y1="120" x2="65"  y2="105" stroke="#1a4731" stroke-width="1.2"/>
    <line x1="100" y1="140" x2="135" y2="125" stroke="#1a4731" stroke-width="1.2"/>
  </svg>
  <svg class="leaf leaf-2" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M100 180 C20 140 10 60 100 20 C190 60 180 140 100 180Z" fill="#40916c"/>
    <line x1="100" y1="20" x2="100" y2="180" stroke="#2d6a4f" stroke-width="2"/>
  </svg>
  <svg class="leaf leaf-3" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M100 180 C20 140 10 60 100 20 C190 60 180 140 100 180Z" fill="#74c69d"/>
  </svg>
  <svg class="leaf leaf-4" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M100 180 C20 140 10 60 100 20 C190 60 180 140 100 180Z" fill="#7d5a3c"/>
  </svg>

  <!-- Card -->
  <div class="card">

    <!-- Badge -->
    <div class="icon-badge">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 22V12" stroke="#d8f3dc" stroke-width="1.8" stroke-linecap="round"/>
        <path d="M12 12C12 12 8 9 8 5C8 2.5 10 1 12 1C14 1 16 2.5 16 5C16 9 12 12 12 12Z" fill="#74c69d"/>
        <path d="M12 14C12 14 7 11.5 5 8C3.5 5.5 4.5 3 6.5 2.5" stroke="#b7e4c7" stroke-width="1.4" stroke-linecap="round"/>
        <path d="M12 16C12 16 17 13.5 19 10C20.5 7.5 19.5 5 17.5 4.5" stroke="#b7e4c7" stroke-width="1.4" stroke-linecap="round"/>
        <path d="M7 21H17" stroke="#d8f3dc" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </div>

    <h1 class="card-title">Selamat Datang</h1>
    <p class="card-subtitle">Masuk untuk melanjutkan perjalanan hijau Anda</p>

    <!-- Error flash -->
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert-error">
      <div class="alert-error-icon">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12" stroke-linecap="round"/>
          <circle cx="12" cy="16" r=".8" fill="currentColor"/>
        </svg>
      </div>
      <div class="alert-error-body">
        <div class="alert-title">Login Gagal</div>
        <div class="alert-msg"><%= error %></div>
      </div>
    </div>
    <% } %>

    <!-- Form -->
    <form action="/login" method="POST" novalidate>

      <!-- Email -->
      <div>
        <label class="field-label" for="email">Email</label>
        <div class="input-wrap">
          <span class="ico-left">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="2" y="4" width="20" height="16" rx="3"/>
              <path d="M2 7l10 7 10-7"/>
            </svg>
          </span>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="email@example.com"
            autocomplete="email"
            required
            value="<%= typeof formEmail !== 'undefined' ? formEmail : '' %>"
          />
          <!-- Tidak ada eye-btn di sini -->
        </div>
      </div>

      <!-- Password -->
      <div>
        <div class="pw-header">
          <label class="field-label" for="password" style="margin-bottom:0">Password</label>
          <a href="/forgot-password">Lupa Password?</a>
        </div>
        <div class="input-wrap" style="margin-top:7px">
          <span class="ico-left">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </span>
          <input
            type="password"
            id="password"
            name="password"
            placeholder="••••••••"
            autocomplete="current-password"
            required
          />
          <!-- Eye button HANYA di password -->
          <button type="button" class="eye-btn" onclick="togglePw()" aria-label="Tampilkan password">
            <svg id="eye-icon" width="17" height="17" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
      </div>

      <button type="submit" class="btn-login">Masuk Sekarang</button>
    </form>

    <!-- Divider -->
    <div class="divider">atau</div>

    <!-- Register -->
    <p class="register-row">
      Belum punya akun? <a href="/register">Daftar sekarang</a>
    </p>

  </div>

  <script>
    function togglePw() {
      const inp  = document.getElementById('password');
      const icon = document.getElementById('eye-icon');
      const show = inp.type === 'password';
      inp.type = show ? 'text' : 'password';
      icon.innerHTML = show
        ? `<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>
           <path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>
           <line x1="1" y1="1" x2="23" y2="23"/>`
        : `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
           <circle cx="12" cy="12" r="3"/>`;
    }

    const colors = ['#74c69d','#40916c','#c9a87c','#b7e4c7','#7d5a3c'];
    for (let i = 0; i < 16; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      const size = Math.random() * 7 + 3;
      p.style.cssText = `
        width:${size}px; height:${size}px;
        left:${Math.random()*100}vw;
        background:${colors[Math.floor(Math.random()*colors.length)]};
        animation-duration:${Math.random()*18+12}s;
        animation-delay:${Math.random()*-20}s;
        border-radius:${Math.random()>0.5?'50%':'30%'};
      `;
      document.body.appendChild(p);
    }
  </script>
</body>
</html>