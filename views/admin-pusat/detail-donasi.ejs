<% layout('layouts/admin-pusat') %>

<style>
  .badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .3px;
  }
  .btn-icon {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: .78rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: background .15s, transform .15s;
  }
  .btn-icon:hover { transform: translateY(-1px); }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-top: 1px solid rgba(116,198,157,.15);
    flex-wrap: wrap;
    gap: 10px;
  }
  .pagination-info { font-size: .78rem; color: var(--brown-mid); }
  .pagination-btns { display: flex; align-items: center; gap: 4px; }
  .pg-btn {
    min-width: 32px; height: 32px;
    border-radius: 8px;
    border: 1.5px solid rgba(116,198,157,.3);
    background: transparent;
    color: var(--green-deep);
    font-family: 'DM Sans', sans-serif;
    font-size: .8rem; font-weight: 500;
    cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0 8px;
    transition: all .15s;
  }
  .pg-btn:hover:not(:disabled) { background: rgba(216,243,220,.5); border-color: var(--green-bright); }
  .pg-btn.active { background: var(--green-bright); border-color: var(--green-bright); color: #fff; font-weight: 600; }
  .pg-btn:disabled { opacity: .35; cursor: not-allowed; }

  .search-wrap { position: relative; }
  .search-wrap input {
    padding: 10px 14px 10px 38px;
    border-radius: 10px;
    border: 1.5px solid rgba(116,198,157,.35);
    background: rgba(255,255,255,.8);
    font-family: 'DM Sans', sans-serif;
    font-size: .875rem; color: var(--green-deep);
    outline: none; width: 220px;
    transition: border-color .2s, box-shadow .2s;
  }
  .search-wrap input:focus {
    border-color: var(--green-bright);
    box-shadow: 0 0 0 3px rgba(64,145,108,.1);
  }
  .search-wrap .search-ico {
    position: absolute; left: 11px; top: 50%;
    transform: translateY(-50%);
    color: #aac8b4; pointer-events: none;
  }
</style>

<!-- Header -->
<div style="margin-bottom:24px">

  <!-- Tombol Back -->
  <a href="/admin-pusat/kelola-program"
     style="display:inline-flex; align-items:center; gap:6px;
            font-size:.82rem; color:var(--brown-mid); text-decoration:none;
            margin-bottom:14px; transition:color .18s"
     onmouseover="this.style.color='var(--green-deep)'"
     onmouseout="this.style.color='var(--brown-mid)'">
    <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Kembali ke Kelola Program
  </a>

  <!-- Header -->
  <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px">
    <div>
      <h2 style="font-family:'Playfair Display',serif; font-size:1.4rem; font-weight:700;
                 color:var(--green-deep); margin-bottom:3px">Data Donasi</h2>
      <p style="font-size:.84rem; color:var(--brown-mid); font-weight:300">
        Riwayat seluruh donasi yang telah berhasil
      </p>
    </div>

    <!-- Search -->
    <div class="search-wrap">
      <span class="search-ico">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35" stroke-linecap="round"/>
        </svg>
      </span>
      <input type="text" id="searchInput" placeholder="Cari nama atau email..." />
    </div>
  </div>

</div>

<!-- Tabel -->
<div style="background:#fff; border:1px solid rgba(116,198,157,.2); border-radius:16px; overflow:hidden">
  <div style="overflow-x:auto">
    <table style="width:100%; border-collapse:collapse; font-size:.875rem; min-width:700px">
      <thead>
        <tr style="background:rgba(216,243,220,.3); border-bottom:1px solid rgba(116,198,157,.18)">
          <th style="padding:13px 18px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">No</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Donatur</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Email</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Jumlah Pohon</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Nominal</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Tanggal</th>
        </tr>
      </thead>
      <tbody id="tableBody">

        <% if (donasis.length === 0) { %>
        <tr>
          <td colspan="6" style="padding:52px; text-align:center; color:#aac8b4">
            <svg width="38" height="38" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                 stroke-width="1.2" style="display:block; margin:0 auto 10px">
              <path d="M12 22V12" stroke-linecap="round"/>
              <path d="M12 12C12 12 8 9 8 5C8 2.5 10 1 12 1C14 1 16 2.5 16 5C16 9 12 12 12 12Z"/>
              <path d="M5 20h14" stroke-linecap="round"/>
            </svg>
            Belum ada donasi berhasil
          </td>
        </tr>
        <% } %>

        <% donasis.forEach((item, index) => { %>
        <tr class="data-row"
            style="border-bottom:1px solid rgba(116,198,157,.08); transition:background .15s"
            onmouseover="this.style.background='rgba(240,250,244,.6)'"
            onmouseout="this.style.background=''">

          <td class="nomor" style="padding:13px 18px; color:#999; font-size:.8rem">
            <%= index + 1 %>
          </td>

          <td class="nama" style="padding:13px 16px; font-weight:500; color:var(--green-deep)">
            <%= item.user.nama_lengkap %>
          </td>

          <td class="email" style="padding:13px 16px; color:#666">
            <%= item.user.email %>
          </td>

          <td style="padding:13px 16px; color:#555">
            <%= item.jumlah_pohon.toLocaleString('id-ID') %> pohon
            </td>

          <td style="padding:13px 16px; font-weight:600; color:#555">
            Rp <%= Number(item.nominal_donasi).toLocaleString('id-ID') %>
          </td>

          <td style="padding:13px 16px; color:#666; font-size:.84rem">
            <%= new Date(item.tanggal_donasi).toLocaleDateString('id-ID', {
              day: '2-digit', month: 'short', year: 'numeric'
            }) %>
          </td>

        </tr>
        <% }) %>

        <tr id="noResultRow" style="display:none">
          <td colspan="6" style="padding:40px; text-align:center; color:#aac8b4; font-size:.875rem">
            Tidak ada data yang cocok
          </td>
        </tr>

      </tbody>
    </table>
  </div>

  <!-- Paginasi -->
  <div class="pagination">
    <span class="pagination-info" id="paginasiInfo"></span>
    <div class="pagination-btns" id="paginasiBtns"></div>
  </div>
</div>

<script>
  const PER_PAGE = 7;
  let allRows      = [];
  let filteredRows = [];
  let currentPage  = 1;

  function initRows() {
    allRows      = Array.from(document.querySelectorAll('.data-row'));
    filteredRows = [...allRows];
    renderPage(1);
  }

  function renderPage(page) {
    currentPage = page;
    const total      = filteredRows.length;
    const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;

    const start = (currentPage - 1) * PER_PAGE;
    const end   = start + PER_PAGE;

    allRows.forEach(r => r.style.display = 'none');
    filteredRows.slice(start, end).forEach((r, i) => {
      r.style.display = '';
      r.querySelector('.nomor').innerText = start + i + 1;
    });

    const noResult = document.getElementById('noResultRow');
    if (noResult) noResult.style.display = total === 0 ? '' : 'none';

    renderPaginasi(currentPage, totalPages, total, start, Math.min(end, total));
  }

  function renderPaginasi(page, totalPages, total, start, end) {
    document.getElementById('paginasiInfo').textContent =
      total === 0 ? 'Tidak ada data' :
      `Menampilkan ${start + 1}–${end} dari ${total} donasi`;

    const container = document.getElementById('paginasiBtns');
    container.innerHTML = '';

    const prev = document.createElement('button');
    prev.className = 'pg-btn';
    prev.innerHTML = `<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    prev.disabled = page <= 1;
    prev.onclick  = () => renderPage(page - 1);
    container.appendChild(prev);

    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || (i >= page - 1 && i <= page + 1)) {
        const btn = document.createElement('button');
        btn.className   = 'pg-btn' + (i === page ? ' active' : '');
        btn.textContent = i;
        btn.onclick     = () => renderPage(i);
        container.appendChild(btn);
      } else if (i === page - 2 || i === page + 2) {
        const dots = document.createElement('span');
        dots.textContent = '…';
        dots.style.cssText = 'color:#aac8b4; font-size:.8rem; padding:0 4px; align-self:center';
        container.appendChild(dots);
      }
    }

    const next = document.createElement('button');
    next.className = 'pg-btn';
    next.innerHTML = `<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    next.disabled = page >= totalPages;
    next.onclick  = () => renderPage(page + 1);
    container.appendChild(next);
  }

  /* Search */
  document.getElementById('searchInput').addEventListener('keyup', function() {
    const keyword = this.value.toLowerCase();
    filteredRows = allRows.filter(row => {
      const nama  = row.querySelector('.nama').innerText.toLowerCase();
      const email = row.querySelector('.email').innerText.toLowerCase();
      return nama.includes(keyword) || email.includes(keyword);
    });
    renderPage(1);
  });

  initRows();
</script>