<% layout('layouts/admin-pusat') %>

<style>
  .badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .3px;
  }
  .badge-role[data-role="admin_wilayah"]     { background: #e8f5e9; color: #2d6a4f; }
  .badge-role[data-role="petugas_lapangan"]  { background: #e3f2fd; color: #1565c0; }
  .badge-role[data-role="pimpinan"]          { background: #f3e5f5; color: #6a1b9a; }
  .badge-aktif    { background: #e8f5e9; color: #2d6a4f; }
  .badge-nonaktif { background: #ffebee; color: #b03030; }

  .btn-icon {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: .78rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: background .15s, transform .15s;
  }
  .btn-icon:hover { transform: translateY(-1px); }

  /* Paginasi */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-top: 1px solid rgba(116,198,157,.15);
    flex-wrap: wrap;
    gap: 10px;
  }
  .pagination-info {
    font-size: .78rem;
    color: var(--brown-mid);
  }
  .pagination-btns {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .pg-btn {
    min-width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1.5px solid rgba(116,198,157,.3);
    background: transparent;
    color: var(--green-deep);
    font-family: 'DM Sans', sans-serif;
    font-size: .8rem;
    font-weight: 500;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 8px;
    transition: all .15s;
  }
  .pg-btn:hover:not(:disabled) {
    background: rgba(216,243,220,.5);
    border-color: var(--green-bright);
  }
  .pg-btn.active {
    background: var(--green-bright);
    border-color: var(--green-bright);
    color: #fff;
    font-weight: 600;
  }
  .pg-btn:disabled {
    opacity: .35;
    cursor: not-allowed;
  }

  /* Modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.35);
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    background: #fff;
    border-radius: 20px;
    padding: 32px;
    width: 100%;
    max-width: 480px;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(26,71,49,.18);
    animation: riseUp .3s cubic-bezier(.22,1,.36,1);
  }
  @keyframes riseUp {
    from { opacity:0; transform:translateY(16px) scale(.97) }
    to   { opacity:1; transform:translateY(0)    scale(1)   }
  }
  .modal-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--green-deep);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .modal-close {
    background: none;
    border: none;
    cursor: pointer;
    color: #aaa;
    font-size: 1.2rem;
    line-height: 1;
    transition: color .15s;
  }
  .modal-close:hover { color: var(--green-deep); }

  .mform-group { margin-bottom: 16px; }
  .mform-label {
    display: block;
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .8px;
    text-transform: uppercase;
    color: var(--green-deep);
    margin-bottom: 6px;
  }
  .mform-wrap { position: relative; }
  .mform-ico {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--green-bright);
    pointer-events: none;
    display: flex;
    align-items: center;
  }
  .mform-input {
    width: 100%;
    padding: 11px 12px 11px 38px;
    border-radius: 10px;
    border: 1.5px solid rgba(116,198,157,.42);
    background: rgba(216,243,220,.18);
    font-family: 'DM Sans', sans-serif;
    font-size: .88rem;
    color: var(--green-deep);
    outline: none;
    box-sizing: border-box;
    appearance: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
  }
  .mform-input::placeholder { color: #aac8b4; }
  .mform-input:focus {
    border-color: var(--green-bright);
    background: rgba(216,243,220,.38);
    box-shadow: 0 0 0 3px rgba(64,145,108,.11);
  }
  .mform-btn {
    width: 100%;
    padding: 12px;
    border: none;
    border-radius: 11px;
    background: linear-gradient(135deg, var(--green-bright), var(--green-deep));
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: .95rem;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(45,106,79,.35);
    transition: transform .18s, box-shadow .18s;
    margin-top: 8px;
  }
  .mform-btn:hover  { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(45,106,79,.42); }
  .mform-btn:active { transform: translateY(0);    box-shadow: 0 3px 8px rgba(45,106,79,.3); }

  .search-wrap { position: relative; }
  .search-wrap input {
    padding: 10px 14px 10px 38px;
    border-radius: 10px;
    border: 1.5px solid rgba(116,198,157,.35);
    background: rgba(255,255,255,.8);
    font-family: 'DM Sans', sans-serif;
    font-size: .875rem;
    color: var(--green-deep);
    outline: none;
    width: 220px;
    transition: border-color .2s, box-shadow .2s;
  }
  .search-wrap input:focus {
    border-color: var(--green-bright);
    box-shadow: 0 0 0 3px rgba(64,145,108,.1);
  }
  .search-wrap .search-ico {
    position: absolute;
    left: 11px;
    top: 50%;
    transform: translateY(-50%);
    color: #aac8b4;
    pointer-events: none;
  }

  .validasi-msg {
    display: none;
    font-size: .75rem;
    color: #b03030;
    text-align: center;
    padding: 8px 12px;
    background: #fff0f0;
    border: 1px solid #f5c6c6;
    border-radius: 8px;
    margin-bottom: 10px;
  }
</style>

<!-- Header -->
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:12px">
  <div>
    <h2 style="font-family:'Playfair Display',serif; font-size:1.4rem; font-weight:700;
               color:var(--green-deep); margin-bottom:3px">Kelola Akun</h2>
    <p style="font-size:.84rem; color:var(--brown-mid); font-weight:300">
      Manajemen akun admin wilayah, petugas lapangan dan pimpinan
    </p>
  </div>
  <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap">
    <div class="search-wrap">
      <span class="search-ico">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35" stroke-linecap="round"/>
        </svg>
      </span>
      <input type="text" id="searchInput" placeholder="Cari nama atau role..." />
    </div>
    <button onclick="openModal('createModal')"
            style="display:inline-flex; align-items:center; gap:7px; padding:10px 18px;
                   border-radius:11px; border:none; cursor:pointer;
                   background:linear-gradient(135deg,var(--green-bright),var(--green-deep));
                   color:#fff; font-family:'DM Sans',sans-serif; font-size:.875rem; font-weight:600;
                   box-shadow:0 4px 14px rgba(45,106,79,.32); transition:transform .18s, box-shadow .18s"
            onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 7px 20px rgba(45,106,79,.42)'"
            onmouseout="this.style.transform='';this.style.boxShadow='0 4px 14px rgba(45,106,79,.32)'">
      <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Tambah Akun
    </button>
  </div>
</div>

<!-- Tabel -->
<div style="background:#fff; border:1px solid rgba(116,198,157,.2); border-radius:16px; overflow:hidden">
  <div style="overflow-x:auto">
    <table style="width:100%; border-collapse:collapse; font-size:.875rem; min-width:700px">
      <thead>
        <tr style="background:rgba(216,243,220,.3); border-bottom:1px solid rgba(116,198,157,.18)">
          <th style="padding:13px 18px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">No</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Nama</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Email</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Telepon</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Role</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Status</th>
          <th style="padding:13px 16px; text-align:center; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Aksi</th>
        </tr>
      </thead>
      <tbody id="tableBody">
        <% if (users.length === 0) { %>
        <tr id="emptyRow">
          <td colspan="7" style="padding:52px; text-align:center; color:#aac8b4">
            <svg width="38" height="38" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                 stroke-width="1.2" style="display:block; margin:0 auto 10px">
              <circle cx="9" cy="7" r="3"/>
              <path d="M3 21v-2a5 5 0 0 1 5-5h2" stroke-linecap="round"/>
              <path d="M16 19l2 2 4-4" stroke-linecap="round"/>
            </svg>
            Belum ada data akun
          </td>
        </tr>
        <% } %>

        <% users.forEach((item, index) => {
          const roleLabels = {
            admin_wilayah:     'Admin Wilayah',
            petugas_lapangan:  'Petugas Lapangan',
            pimpinan:          'Pimpinan',
          };
          const roleLabel = roleLabels[item.role] || item.role;
        %>
        <tr class="data-row"
            style="border-bottom:1px solid rgba(116,198,157,.08); transition:background .15s"
            onmouseover="this.style.background='rgba(240,250,244,.6)'"
            onmouseout="this.style.background=''">

          <td class="nomor" style="padding:13px 18px; color:#999; font-size:.8rem"><%= index + 1 %></td>

          <td class="nama" style="padding:13px 16px; font-weight:500; color:var(--green-deep)">
            <%= item.nama_lengkap %>
          </td>

          <td class="email" style="padding:13px 16px; color:#666"><%= item.email %></td>
          <td style="padding:13px 16px; color:#666"><%= item.no_telepon %></td>

          <td class="role-cell" style="padding:13px 16px">
            <span class="badge badge-role" data-role="<%= item.role %>">
              <%= roleLabel %>
            </span>
          </td>

          <td style="padding:13px 16px">
            <span class="badge <%= item.status === 'aktif' ? 'badge-aktif' : 'badge-nonaktif' %>">
              <%= item.status === 'aktif' ? 'Aktif' : 'Nonaktif' %>
            </span>
          </td>

          <td style="padding:13px 16px">
            <div style="display:flex; align-items:center; justify-content:center; gap:7px">
              <button class="btn-icon btnEdit"
                      style="background:rgba(216,243,220,.5); color:var(--green-deep); border:1px solid rgba(116,198,157,.3)"
                      onmouseover="this.style.background='rgba(116,198,157,.3)'"
                      onmouseout="this.style.background='rgba(216,243,220,.5)'"
                      data-id="<%= item.id_user %>"
                      data-nama="<%= item.nama_lengkap %>"
                      data-email="<%= item.email %>"
                      data-telepon="<%= item.no_telepon %>"
                      data-role="<%= item.role %>"
                      data-provinsi="<%= item.kode_provinsi || '' %>"
                      data-status="<%= item.status %>">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Edit
              </button>
              <form action="/admin-pusat/kelola-akun/delete/<%= item.id_user %>" method="POST"
                    onsubmit="return confirmHapus(event, '<%= item.nama_lengkap %>')">
                <button type="submit" class="btn-icon"
                        style="background:rgba(255,235,235,.6); color:#b03030; border:1px solid rgba(240,180,180,.35)"
                        onmouseover="this.style.background='rgba(240,180,180,.4)'"
                        onmouseout="this.style.background='rgba(255,235,235,.6)'">
                  <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                  </svg>
                  Hapus
                </button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>

        <!-- Row kosong saat search tidak ada hasil -->
        <tr id="noResultRow" style="display:none">
          <td colspan="7" style="padding:40px; text-align:center; color:#aac8b4; font-size:.875rem">
            Tidak ada data yang cocok
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Paginasi -->
  <div class="pagination">
    <span class="pagination-info" id="paginasiInfo"></span>
    <div class="pagination-btns" id="paginasiBtns"></div>
  </div>
</div>


<!-- MODAL CREATE -->
<div id="createModal" class="modal-overlay">
  <div class="modal-box">
    <div class="modal-title">
      Tambah Akun
      <button class="modal-close" onclick="closeModal('createModal')">✕</button>
    </div>
    <form action="/admin-pusat/kelola-akun/create" method="POST" id="createForm">

      <div class="mform-group">
        <label class="mform-label">Nama Lengkap</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="8" r="4"/>
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke-linecap="round"/>
            </svg>
          </span>
          <input type="text" name="nama_lengkap" placeholder="Nama lengkap" class="mform-input" />
        </div>
      </div>

      <div class="mform-group">
        <label class="mform-label">Email</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="2" y="4" width="20" height="16" rx="3"/>
              <path d="M2 7l10 7 10-7"/>
            </svg>
          </span>
          <input type="email" name="email" placeholder="email@example.com" class="mform-input" />
        </div>
      </div>

      <div class="mform-group">
        <label class="mform-label">Nomor Telepon</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.86 19.86 0 0 1 3.08 4.18 2 2 0 0 1 5.07 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L9.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <input type="tel" name="no_telepon" placeholder="08xxxxxxxxxx" class="mform-input" />
        </div>
      </div>

      <div class="mform-group">
        <label class="mform-label">Password</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </span>
          <input type="password" name="password" placeholder="Minimal 8 karakter"
                 class="mform-input" style="padding-right:40px" id="createPw"/>
          <button type="button" style="position:absolute;right:11px;top:50%;transform:translateY(-50%);
                  background:none;border:none;cursor:pointer;color:#aac8b4;display:flex;padding:0"
                  onclick="togglePw('createPw','eyeCreate')">
            <svg id="eyeCreate" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="mform-group">
        <label class="mform-label">Role</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
            </svg>
          </span>
          <select name="role" id="createRole" class="mform-input" onchange="toggleCreateProvinsi()">
            <option value="" disabled selected>Pilih role</option>
            <option value="admin_wilayah">Admin Wilayah</option>
            <option value="petugas_lapangan">Petugas Lapangan</option>
            <option value="pimpinan">Pimpinan</option>
          </select>
        </div>
      </div>

      <div class="mform-group" id="createProvinsiBox" style="display:none">
        <label class="mform-label">Provinsi</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </span>
          <select name="kode_provinsi" id="createProvinsi" class="mform-input">
            <option value="" disabled selected>Pilih provinsi</option>
            <% provinces.forEach(p => { %>
            <option value="<%= p.code %>"><%= p.name %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <p id="createValidasi" class="validasi-msg">Silahkan lengkapi data</p>
      <button type="submit" class="mform-btn">Simpan Akun</button>
    </form>
  </div>
</div>


<!-- MODAL EDIT -->
<div id="editModal" class="modal-overlay">
  <div class="modal-box">
    <div class="modal-title">
      Edit Akun
      <button class="modal-close" onclick="closeModal('editModal')">✕</button>
    </div>
    <form id="editForm" method="POST">

      <div class="mform-group">
        <label class="mform-label">Nama Lengkap</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="8" r="4"/>
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke-linecap="round"/>
            </svg>
          </span>
          <input type="text" id="editNama" name="nama_lengkap" class="mform-input" />
        </div>
      </div>

      <div class="mform-group">
        <label class="mform-label">Email</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="2" y="4" width="20" height="16" rx="3"/>
              <path d="M2 7l10 7 10-7"/>
            </svg>
          </span>
          <input type="email" id="editEmail" name="email" class="mform-input" />
        </div>
      </div>

      <div class="mform-group">
        <label class="mform-label">Nomor Telepon</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.86 19.86 0 0 1 3.08 4.18 2 2 0 0 1 5.07 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L9.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <input type="tel" id="editTelepon" name="no_telepon" class="mform-input" />
        </div>
      </div>

      <div class="mform-group">
        <label class="mform-label">Role</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
            </svg>
          </span>
          <select name="role" id="editRole" class="mform-input" onchange="toggleEditProvinsi()">
            <option value="admin_wilayah">Admin Wilayah</option>
            <option value="petugas_lapangan">Petugas Lapangan</option>
            <option value="pimpinan">Pimpinan</option>
          </select>
        </div>
      </div>

      <div class="mform-group" id="editProvinsiBox" style="display:none">
        <label class="mform-label">Provinsi</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </span>
          <select name="kode_provinsi" id="editProvinsi" class="mform-input">
            <option value="" disabled>Pilih provinsi</option>
            <% provinces.forEach(p => { %>
            <option value="<%= p.code %>"><%= p.name %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="mform-group">
        <label class="mform-label">Status</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 8v4l3 3" stroke-linecap="round"/>
            </svg>
          </span>
          <select name="status" id="editStatus" class="mform-input">
            <option value="aktif">Aktif</option>
            <option value="nonaktif">Nonaktif</option>
          </select>
        </div>
      </div>

      <p id="editValidasi" class="validasi-msg">Silahkan lengkapi data</p>
      <button type="submit" class="mform-btn">Simpan Perubahan</button>
    </form>
  </div>
</div>


<!-- Modal Konfirmasi Hapus -->
<div id="hapusModal" class="modal-overlay">
  <div class="modal-box" style="max-width:360px; text-align:center">
    <div style="width:52px;height:52px;border-radius:50%;background:#ffebee;
                display:flex;align-items:center;justify-content:center;margin:0 auto 14px">
      <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#b03030" stroke-width="2">
        <polyline points="3 6 5 6 21 6"/>
        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
      </svg>
    </div>
    <h3 style="font-family:'Playfair Display',serif; font-size:1.1rem; color:var(--green-deep); margin-bottom:8px">
      Hapus Akun?
    </h3>
    <p id="hapusNama" style="font-size:.875rem; color:var(--brown-mid); margin-bottom:22px"></p>
    <div style="display:flex; gap:10px; justify-content:center">
      <button onclick="closeModal('hapusModal')"
              style="padding:9px 22px; border-radius:10px; border:1.5px solid rgba(116,198,157,.35);
                     background:transparent; color:var(--green-deep); font-family:'DM Sans',sans-serif;
                     font-size:.875rem; font-weight:500; cursor:pointer">
        Batal
      </button>
      <button id="hapusConfirmBtn"
              style="padding:9px 22px; border-radius:10px; border:none; background:#c0392b;
                     color:#fff; font-family:'DM Sans',sans-serif; font-size:.875rem;
                     font-weight:600; cursor:pointer">
        Ya, Hapus
      </button>
    </div>
  </div>
</div>


<script>
  /* ── Paginasi ── */
  const PER_PAGE    = 7;
  let allRows       = [];
  let filteredRows  = [];
  let currentPage   = 1;

  function initRows() {
    allRows      = Array.from(document.querySelectorAll('.data-row'));
    filteredRows = [...allRows];
    renderPage(1);
  }

  function renderPage(page) {
    currentPage = page;
    const total      = filteredRows.length;
    const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;

    const start = (currentPage - 1) * PER_PAGE;
    const end   = start + PER_PAGE;

    // Sembunyikan semua dulu
    allRows.forEach(r => r.style.display = 'none');

    // Tampilkan slice halaman ini & update nomor urut
    filteredRows.slice(start, end).forEach((r, i) => {
      r.style.display = '';
      r.querySelector('.nomor').innerText = start + i + 1;
    });

    // Tampilkan row "tidak ada hasil" jika perlu
    const noResult = document.getElementById('noResultRow');
    if (noResult) noResult.style.display = total === 0 ? '' : 'none';

    renderPaginasi(currentPage, totalPages, total, start, Math.min(end, total));
  }

  function renderPaginasi(page, totalPages, total, start, end) {
    document.getElementById('paginasiInfo').textContent =
      total === 0 ? 'Tidak ada data' :
      `Menampilkan ${start + 1}–${end} dari ${total} akun`;

    const container = document.getElementById('paginasiBtns');
    container.innerHTML = '';

    // Tombol Sebelumnya
    const prev = document.createElement('button');
    prev.className = 'pg-btn';
    prev.innerHTML = `<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    prev.title    = 'Sebelumnya';
    prev.disabled = page <= 1;
    prev.onclick  = () => renderPage(page - 1);
    container.appendChild(prev);

    // Nomor halaman
    for (let i = 1; i <= totalPages; i++) {
      // Tampilkan: halaman 1, halaman terakhir, dan halaman di sekitar current
      if (
        i === 1 || i === totalPages ||
        (i >= page - 1 && i <= page + 1)
      ) {
        const btn = document.createElement('button');
        btn.className = 'pg-btn' + (i === page ? ' active' : '');
        btn.textContent = i;
        btn.onclick = () => renderPage(i);
        container.appendChild(btn);
      } else if (
        i === page - 2 || i === page + 2
      ) {
        // Ellipsis
        const dots = document.createElement('span');
        dots.textContent = '…';
        dots.style.cssText = 'color:#aac8b4; font-size:.8rem; padding:0 4px; align-self:center';
        container.appendChild(dots);
      }
    }

    // Tombol Sesudah
    const next = document.createElement('button');
    next.className = 'pg-btn';
    next.innerHTML = `<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    next.title    = 'Sesudahnya';
    next.disabled = page >= totalPages;
    next.onclick  = () => renderPage(page + 1);
    container.appendChild(next);
  }

  /* ── Search ── */
  document.getElementById('searchInput').addEventListener('keyup', function() {
    const keyword = this.value.toLowerCase();
    filteredRows = allRows.filter(row => {
      const nama  = row.querySelector('.nama').innerText.toLowerCase();
      const email = row.querySelector('.role-cell').innerText.toLowerCase();
      return nama.includes(keyword) || email.includes(keyword);
    });
    renderPage(1);
  });

  /* ── Modal helpers ── */
  function openModal(id)  { document.getElementById(id).classList.add('open');    }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }

  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', function(e) {
      if (e.target === this) this.classList.remove('open');
    });
  });

  /* ── Toggle password ── */
  function togglePw(fieldId, iconId) {
    const inp  = document.getElementById(fieldId);
    const icon = document.getElementById(iconId);
    const show = inp.type === 'password';
    inp.type = show ? 'text' : 'password';
    icon.innerHTML = show
      ? `<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>
         <path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>
         <line x1="1" y1="1" x2="23" y2="23"/>`
      : `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
         <circle cx="12" cy="12" r="3"/>`;
  }

  /* ── Toggle provinsi ── */
  function toggleCreateProvinsi() {
    const role = document.getElementById('createRole').value;
    document.getElementById('createProvinsiBox').style.display =
      role === 'admin_wilayah' ? 'block' : 'none';
  }
  function toggleEditProvinsi() {
    const role = document.getElementById('editRole').value;
    document.getElementById('editProvinsiBox').style.display =
      role === 'admin_wilayah' ? 'block' : 'none';
  }

  /* ── Edit button ── */
  document.querySelectorAll('.btnEdit').forEach(btn => {
    btn.addEventListener('click', function() {
      document.getElementById('editNama').value    = this.dataset.nama;
      document.getElementById('editEmail').value   = this.dataset.email;
      document.getElementById('editTelepon').value = this.dataset.telepon;
      document.getElementById('editRole').value    = this.dataset.role;
      document.getElementById('editStatus').value  = this.dataset.status;
      document.getElementById('editForm').action   =
        '/admin-pusat/kelola-akun/edit/' + this.dataset.id;
      toggleEditProvinsi();
      if (this.dataset.provinsi) {
        document.getElementById('editProvinsi').value = this.dataset.provinsi;
      }
      openModal('editModal');
    });
  });

  /* ── Konfirmasi hapus ── */
  let pendingHapusForm = null;
  function confirmHapus(e, nama) {
    e.preventDefault();
    pendingHapusForm = e.target.closest('form');
    document.getElementById('hapusNama').textContent =
      'Akun "' + nama + '" akan dihapus permanen dan tidak dapat dikembalikan.';
    openModal('hapusModal');
  }
  document.getElementById('hapusConfirmBtn').addEventListener('click', () => {
    if (pendingHapusForm) pendingHapusForm.submit();
  });

  /* ── Validasi create ── */
  document.getElementById('createForm').addEventListener('submit', function(e) {
    const nama = this.nama_lengkap.value.trim();
    const email = this.email.value.trim();
    const telp  = this.no_telepon.value.trim();
    const pw    = this.password.value;
    const role  = this.role.value;
    const prov  = document.getElementById('createProvinsi').value;
    const msg   = document.getElementById('createValidasi');
    const needProv = role === 'admin_wilayah' && !prov;
    if (!nama || !email || !telp || !pw || !role || needProv) {
      e.preventDefault();
      msg.style.display = 'block';
      msg.textContent = needProv ? 'Pilih provinsi untuk Admin Wilayah' : 'Silahkan lengkapi data';
    } else {
      msg.style.display = 'none';
    }
  });

  /* ── Validasi edit ── */
  document.getElementById('editForm').addEventListener('submit', function(e) {
    const nama  = document.getElementById('editNama').value.trim();
    const email = document.getElementById('editEmail').value.trim();
    const telp  = document.getElementById('editTelepon').value.trim();
    const role  = document.getElementById('editRole').value;
    const prov  = document.getElementById('editProvinsi').value;
    const msg   = document.getElementById('editValidasi');
    const needProv = role === 'admin_wilayah' && !prov;
    if (!nama || !email || !telp || !role || needProv) {
      e.preventDefault();
      msg.style.display = 'block';
      msg.textContent = needProv ? 'Pilih provinsi untuk Admin Wilayah' : 'Silahkan lengkapi data';
    } else {
      msg.style.display = 'none';
    }
  });

  document.querySelectorAll('.mform-input').forEach(el => {
    el.addEventListener('input',  () => {
      document.getElementById('createValidasi').style.display = 'none';
      document.getElementById('editValidasi').style.display   = 'none';
    });
    el.addEventListener('change', () => {
      document.getElementById('createValidasi').style.display = 'none';
      document.getElementById('editValidasi').style.display   = 'none';
    });
  });

  initRows();
</script>