<% layout('layouts/admin-pusat') %>

<style>
  .badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .3px;
  }
  .badge-aktif    { background: #e8f5e9; color: #2d6a4f; }
  .badge-selesai  { background: #fff3e0; color: #7d5a3c; }

  .btn-icon {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: .78rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: background .15s, transform .15s;
  }
  .btn-icon:hover { transform: translateY(-1px); }

  /* Paginasi */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-top: 1px solid rgba(116,198,157,.15);
    flex-wrap: wrap;
    gap: 10px;
  }
  .pagination-info { font-size: .78rem; color: var(--brown-mid); }
  .pagination-btns { display: flex; align-items: center; gap: 4px; }
  .pg-btn {
    min-width: 32px; height: 32px;
    border-radius: 8px;
    border: 1.5px solid rgba(116,198,157,.3);
    background: transparent;
    color: var(--green-deep);
    font-family: 'DM Sans', sans-serif;
    font-size: .8rem; font-weight: 500;
    cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0 8px;
    transition: all .15s;
  }
  .pg-btn:hover:not(:disabled) { background: rgba(216,243,220,.5); border-color: var(--green-bright); }
  .pg-btn.active { background: var(--green-bright); border-color: var(--green-bright); color: #fff; font-weight: 600; }
  .pg-btn:disabled { opacity: .35; cursor: not-allowed; }

  /* Modal */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.35);
    z-index: 100; display: none;
    align-items: center; justify-content: center;
    padding: 16px;
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    background: #fff;
    border-radius: 20px;
    padding: 32px;
    width: 100%; max-width: 560px;
    max-height: 90vh; overflow-y: auto;
    box-shadow: 0 20px 60px rgba(26,71,49,.18);
    animation: riseUp .3s cubic-bezier(.22,1,.36,1);
  }
  @keyframes riseUp {
    from { opacity:0; transform:translateY(16px) scale(.97) }
    to   { opacity:1; transform:translateY(0)    scale(1)   }
  }
  .modal-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem; font-weight: 700;
    color: var(--green-deep);
    margin-bottom: 20px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .modal-close {
    background: none; border: none; cursor: pointer;
    color: #aaa; font-size: 1.2rem; line-height: 1;
    transition: color .15s;
  }
  .modal-close:hover { color: var(--green-deep); }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .form-grid .full { grid-column: 1 / -1; }

  .mform-group { margin-bottom: 0; }
  .mform-label {
    display: block; font-size: .7rem; font-weight: 600;
    letter-spacing: .8px; text-transform: uppercase;
    color: var(--green-deep); margin-bottom: 6px;
  }
  .mform-wrap { position: relative; }
  .mform-ico {
    position: absolute; left: 12px; top: 50%;
    transform: translateY(-50%);
    color: var(--green-bright); pointer-events: none;
    display: flex; align-items: center;
  }
  .mform-input {
    width: 100%;
    padding: 11px 12px 11px 14px;
    border-radius: 10px;
    border: 1.5px solid rgba(116,198,157,.42);
    background: rgba(216,243,220,.18);
    font-family: 'DM Sans', sans-serif;
    font-size: .88rem; color: var(--green-deep);
    outline: none; box-sizing: border-box; appearance: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
  }
  .mform-input-loc { padding-left: 38px; }
  .mform-input::placeholder { color: #aac8b4; }
  .mform-input:focus {
    border-color: var(--green-bright);
    background: rgba(216,243,220,.38);
    box-shadow: 0 0 0 3px rgba(64,145,108,.11);
  }
  .mform-input:disabled {
    opacity: .5; cursor: not-allowed;
    background: rgba(0,0,0,.04);
  }
  textarea.mform-input { resize: vertical; min-height: 80px; padding-top: 11px; }

  input[type="number"].mform-input::-webkit-outer-spin-button,
  input[type="number"].mform-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  input[type="number"].mform-input { -moz-appearance: textfield; }

  .mform-btn {
    width: 100%; padding: 12px; border: none; border-radius: 11px;
    background: linear-gradient(135deg, var(--green-bright), var(--green-deep));
    color: #fff; font-family: 'DM Sans', sans-serif;
    font-size: .95rem; font-weight: 600; cursor: pointer;
    box-shadow: 0 4px 16px rgba(45,106,79,.35);
    transition: transform .18s, box-shadow .18s; margin-top: 16px;
  }
  .mform-btn:hover  { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(45,106,79,.42); }
  .mform-btn:active { transform: translateY(0);    box-shadow: 0 3px 8px rgba(45,106,79,.3); }

  /* Upload Flyer */
  .img-preview {
    width: 100%; height: 150px;
    border-radius: 10px;
    border: 1.5px dashed rgba(116,198,157,.5);
    background: rgba(216,243,220,.1);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 6px;
    cursor: pointer; overflow: hidden;
    transition: border-color .2s, background .2s;
    position: relative;
  }
  .img-preview:hover { border-color: var(--green-bright); background: rgba(216,243,220,.25); }
  .img-preview img { width: 100%; height: 100%; object-fit: cover; display: none; }
  .upload-hint {
    display: flex; flex-direction: column;
    align-items: center; gap: 5px;
    color: #aac8b4; font-size: .78rem; text-align: center;
    pointer-events: none;
  }
  input[type="file"] { display: none; }

  /* Search */
  .search-wrap { position: relative; }
  .search-wrap input {
    padding: 10px 36px 10px 38px;
    border-radius: 10px;
    border: 1.5px solid rgba(116,198,157,.35);
    background: rgba(255,255,255,.8);
    font-family: 'DM Sans', sans-serif;
    font-size: .875rem; color: var(--green-deep);
    outline: none; width: 230px;
    transition: border-color .2s, box-shadow .2s;
  }
  .search-wrap input:focus {
    border-color: var(--green-bright);
    box-shadow: 0 0 0 3px rgba(64,145,108,.1);
  }
  .search-wrap .search-ico {
    position: absolute; left: 11px; top: 50%;
    transform: translateY(-50%);
    color: #aac8b4; pointer-events: none;
    display: flex; align-items: center;
  }

  /* Tombol filter di dalam search */
  #btnFilterToggle {
    position: absolute; right: 9px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none; cursor: pointer;
    padding: 3px; display: flex; align-items: center;
    color: #aac8b4; transition: color .15s; line-height: 1;
  }
  #btnFilterToggle:hover { color: var(--green-bright); }
  #btnFilterToggle.active { color: var(--green-bright); }

  /* Popup filter */
  #filterPopup {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: 280px;
    background: #fff;
    z-index: 300;
    border: 1.5px solid rgba(116,198,157,.3);
    border-radius: 14px;
    padding: 18px;
    box-shadow: 0 8px 28px rgba(26,71,49,.14);
  }

  /* Chip filter */
  .filter-chip {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: .72rem; font-weight: 600;
    background: rgba(216,243,220,.7); color: #2d6a4f;
    border-radius: 20px; padding: 3px 10px;
    cursor: pointer; border: 1px solid rgba(116,198,157,.3);
    transition: background .15s;
  }
  .filter-chip:hover { background: rgba(116,198,157,.3); }
  .filter-chip svg { flex-shrink: 0; }

  .validasi-msg {
    display: none; font-size: .75rem; color: #b03030;
    text-align: center; padding: 8px 12px;
    background: #fff0f0; border: 1px solid #f5c6c6;
    border-radius: 8px; margin-top: 12px;
  }

  .wilayah-loading {
    display: none; font-size: .75rem; color: var(--brown-mid);
    padding: 5px 0; align-items: center; gap: 6px;
  }
  .spinner {
    width: 14px; height: 14px;
    border: 2px solid rgba(116,198,157,.3);
    border-top-color: var(--green-bright);
    border-radius: 50%;
    animation: spin .7s linear infinite; flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .wilayah-cell-text { font-size: .78rem; color: #555; line-height: 1.6; }
  .wilayah-cell-text span { display: block; }
</style>


<!-- ═══ HEADER ═══ -->
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; flex-wrap:wrap; gap:12px">
  <div>
    <h2 style="font-family:'Playfair Display',serif; font-size:1.4rem; font-weight:700;
               color:var(--green-deep); margin-bottom:3px">Kelola Program Donasi</h2>
    <p style="font-size:.84rem; color:var(--brown-mid); font-weight:300">
      Buat dan kelola program donasi bibit pohon
    </p>
  </div>

  <!-- Kanan: search + tombol (position:relative sebagai anchor popup) -->
  <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; position:relative">

    <!-- Search + icon filter -->
    <div class="search-wrap">
      <span class="search-ico">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35" stroke-linecap="round"/>
        </svg>
      </span>
      <input type="text" id="searchInput" placeholder="Cari judul program..." autocomplete="off" />
      <button id="btnFilterToggle" title="Filter wilayah" onclick="toggleFilterPopup(event)">
        <svg id="filterIcon" width="14" height="14" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2">
          <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
        </svg>
        <span id="filterDot" style="display:none; position:absolute; top:0; right:0;
               width:7px; height:7px; border-radius:50%;
               background:var(--green-bright); border:1.5px solid #fff;
               pointer-events:none"></span>
      </button>
    </div>

    <!-- Tombol Tambah -->
    <button id="btnTambah"
            style="display:inline-flex; align-items:center; gap:7px; padding:10px 18px;
                   border-radius:11px; border:none; cursor:pointer;
                   background:linear-gradient(135deg,var(--green-bright),var(--green-deep));
                   color:#fff; font-family:'DM Sans',sans-serif; font-size:.875rem; font-weight:600;
                   box-shadow:0 4px 14px rgba(45,106,79,.32); transition:transform .18s, box-shadow .18s"
            onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 7px 20px rgba(45,106,79,.42)'"
            onmouseout="this.style.transform='';this.style.boxShadow='0 4px 14px rgba(45,106,79,.32)'">
      <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Tambah Program
    </button>

    <!-- ═══ POPUP FILTER ═══ -->
    <div id="filterPopup">
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px">
        <span style="font-size:.82rem; font-weight:600; color:var(--green-deep);
                     display:flex; align-items:center; gap:6px">
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24"
               stroke="var(--green-bright)" stroke-width="2">
            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
          </svg>
          Filter Wilayah
        </span>
        <button onclick="closeFilterPopup()"
                style="background:none; border:none; cursor:pointer; color:#aac8b4;
                       font-size:1rem; line-height:1; padding:2px; transition:color .15s"
                onmouseover="this.style.color='var(--green-deep)'"
                onmouseout="this.style.color='#aac8b4'">✕</button>
      </div>

      <!-- Provinsi -->
      <div style="margin-bottom:12px">
        <label class="mform-label">Provinsi</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </span>
          <select id="filterProvinsi" class="mform-input mform-input-loc"
                  onchange="onFilterProvinsiChange()">
            <option value="">Semua provinsi</option>
          </select>
        </div>
      </div>

      <!-- Kab/Kota -->
      <div style="margin-bottom:18px">
        <label class="mform-label">Kabupaten / Kota</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </span>
          <select id="filterKota" class="mform-input mform-input-loc" disabled>
            <option value="">Semua kab/kota</option>
          </select>
        </div>
      </div>

      <!-- Aksi popup -->
      <div style="display:flex; gap:8px">
        <button onclick="resetFilters()"
                style="flex:1; padding:9px; border-radius:9px;
                       border:1.5px solid rgba(116,198,157,.4); background:transparent;
                       color:var(--green-deep); font-family:'DM Sans',sans-serif;
                       font-size:.8rem; font-weight:500; cursor:pointer; transition:background .15s"
                onmouseover="this.style.background='rgba(216,243,220,.4)'"
                onmouseout="this.style.background='transparent'">
          Reset
        </button>
        <button onclick="applyFilters(); closeFilterPopup()"
                style="flex:2; padding:9px; border-radius:9px; border:none;
                       background:linear-gradient(135deg,var(--green-bright),var(--green-deep));
                       color:#fff; font-family:'DM Sans',sans-serif;
                       font-size:.8rem; font-weight:600; cursor:pointer; transition:transform .15s"
                onmouseover="this.style.transform='translateY(-1px)'"
                onmouseout="this.style.transform=''">
          Terapkan Filter
        </button>
      </div>
    </div>
    <!-- /POPUP FILTER -->

  </div>
  <!-- /Kanan -->
</div>


<!-- Chip filter aktif -->
<div id="filterChips" style="display:none; margin-bottom:12px; align-items:center; gap:6px; flex-wrap:wrap">
  <span style="font-size:.75rem; color:var(--brown-mid)">Filter:</span>
  <span id="chipProvinsi" class="filter-chip" style="display:none" onclick="resetProvinsiFilter()">
    <span id="chipProvinsiText"></span>
    <svg width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </span>
  <span id="chipKota" class="filter-chip" style="display:none" onclick="resetKotaFilter()">
    <span id="chipKotaText"></span>
    <svg width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </span>
</div>


<!-- ═══ TABEL ═══ -->
<div style="background:#fff; border:1px solid rgba(116,198,157,.2); border-radius:16px; overflow:hidden">
  <div style="overflow-x:auto">
    <table style="width:100%; border-collapse:collapse; font-size:.875rem; min-width:1000px">
      <thead>
        <tr style="background:rgba(216,243,220,.3); border-bottom:1px solid rgba(116,198,157,.18)">
          <th style="padding:13px 18px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">No</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Program</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Harga/Pohon</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Periode</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Wilayah</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Status</th>
          <th style="padding:13px 16px; text-align:center; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Aksi</th>
        </tr>
      </thead>
      <tbody id="tableBody">

        <% if (programs.length === 0) { %>
        <tr>
          <td colspan="7" style="padding:52px; text-align:center; color:#aac8b4">
            <p style="margin:0; font-size:.875rem">Belum ada program donasi</p>
          </td>
        </tr>
        <% } %>

        <% programs.forEach((item, index) => {
          const statusCls = item.status_program === 'aktif' ? 'badge-aktif' : 'badge-selesai';
          const fmtTgl = (tgl) => tgl ? new Date(tgl).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) : '-';
          const fmtRp  = (n)   => 'Rp ' + Number(n).toLocaleString('id-ID');
        %>
        <tr class="data-row"
            style="border-bottom:1px solid rgba(116,198,157,.08); transition:background .15s"
            onmouseover="this.style.background='rgba(240,250,244,.6)'"
            onmouseout="this.style.background=''">

          <td class="nomor" style="padding:13px 18px; color:#999; font-size:.8rem"><%= index + 1 %></td>

          <td class="judul" style="padding:13px 16px">
            <div style="font-weight:500; color:var(--green-deep); margin-bottom:2px"><%= item.judul_program %></div>
            <div style="font-size:.72rem; color:#999"><%= item.pohon_terkumpul || 0 %> pohon terkumpul</div>
          </td>

          <td style="padding:13px 16px; color:#555"><%= fmtRp(item.harga_pohon) %></td>

          <td style="padding:13px 16px; color:#555; font-size:.82rem">
            <div><%= fmtTgl(item.tanggal_mulai) %></div>
            <div>s/d <%= fmtTgl(item.tanggal_selesai) %></div>
          </td>

          <td style="padding:13px 16px; max-width:180px">
            <div class="wilayah-cell-text" style="white-space:normal; word-break:break-word; line-height:1.5">
              <% if (item.nama_kelurahan || item.nama_kecamatan || item.nama_kota || item.nama_provinsi) { %>
                <span><%= [item.nama_kelurahan, item.nama_kecamatan, item.nama_kota, item.nama_provinsi].filter(Boolean).join(', ') %></span>
              <% } else { %>
                <span style="color:#ccc; font-style:italic">—</span>
              <% } %>
            </div>
          </td>

          <td style="padding:13px 16px">
            <span class="badge <%= statusCls %>">
              <%= item.status_program === 'aktif' ? 'Aktif' : 'Selesai' %>
            </span>
          </td>

          <td style="padding:13px 16px">
            <div style="display:flex; align-items:center; justify-content:center; gap:5px; flex-wrap:wrap">

              <button class="btn-icon btnDetail"
                      style="background:rgba(227,242,253,.6); color:#1565c0; border:1px solid rgba(100,181,246,.35)"
                      onmouseover="this.style.background='rgba(100,181,246,.25)'"
                      onmouseout="this.style.background='rgba(227,242,253,.6)'"
                      onclick="window.location.href='/admin-pusat/program/<%= item.id_program %>/donatur'"
                      data-id="<%= item.id_program %>">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="12" y1="8" x2="12" y2="12"/>
                  <line x1="12" y1="16" x2="12.01" y2="16" stroke-linecap="round"/>
                </svg>
                Detail
              </button>

              <button class="btn-icon btnEdit"
                      style="background:rgba(216,243,220,.5); color:var(--green-deep); border:1px solid rgba(116,198,157,.3)"
                      onmouseover="this.style.background='rgba(116,198,157,.3)'"
                      onmouseout="this.style.background='rgba(216,243,220,.5)'"
                      data-id="<%= item.id_program %>"
                      data-judul="<%= item.judul_program %>"
                      data-deskripsi="<%= item.deskripsi %>"
                      data-harga="<%= item.harga_pohon %>"
                      data-mulai="<%= item.tanggal_mulai ? item.tanggal_mulai.toString().slice(0,10) : '' %>"
                      data-selesai="<%= item.tanggal_selesai ? item.tanggal_selesai.toString().slice(0,10) : '' %>"
                      data-status="<%= item.status_program %>"
                      data-provinsi="<%= item.kode_provinsi || '' %>"
                      data-kota="<%= item.kode_kbp_kota || '' %>"
                      data-kecamatan="<%= item.kode_kecamatan || '' %>"
                      data-kelurahan="<%= item.kode_kelurahan || '' %>"
                      data-flyer="<%= item.flyer_program || '' %>">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Edit
              </button>

              <form action="/admin-pusat/kelola-program/delete/<%= item.id_program %>" method="POST"
                    onsubmit="return confirmHapus(event, '<%= item.judul_program %>')">
                <button type="submit" class="btn-icon"
                        style="background:rgba(255,235,235,.6); color:#b03030; border:1px solid rgba(240,180,180,.35)"
                        onmouseover="this.style.background='rgba(240,180,180,.4)'"
                        onmouseout="this.style.background='rgba(255,235,235,.6)'">
                  <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                  </svg>
                  Hapus
                </button>
              </form>

            </div>
          </td>
        </tr>
        <% }) %>

        <tr id="noResultRow" style="display:none">
          <td colspan="7" style="padding:40px; text-align:center; color:#aac8b4; font-size:.875rem">
            Tidak ada program yang cocok
          </td>
        </tr>
      </tbody>
