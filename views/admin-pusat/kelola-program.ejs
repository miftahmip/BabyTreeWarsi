<script>
  /* ════ TANGGAL MIN ════ */
  function setDateMin() {
    const today  = new Date().toISOString().split('T')[0];
    const cSelesai = document.getElementById('c_tanggal_selesai');
    if (cSelesai) cSelesai.min = today;

    const eMulai   = document.getElementById('e_mulai');
    const eSelesai = document.getElementById('e_selesai');
    if (eMulai && eSelesai) {
      eSelesai.min = eMulai.value || today;
      if (eSelesai.value && eSelesai.value < eMulai.value) eSelesai.value = '';
    }
  }

  /* ════ WILAYAH ════ */
  async function loadWilayah(prefix, level, code) {
    if (!code) return;
    const urlMap    = { regency: `/api/regencies/${code}`, district: `/api/districts/${code}`, village: `/api/villages/${code}` };
    const targetMap = { regency: prefix+'_kota', district: prefix+'_kecamatan', village: prefix+'_kelurahan' };
    const loadMap   = { regency: prefix+'_loading_regency', district: prefix+'_loading_district', village: prefix+'_loading_village' };

    if (level === 'regency')  { resetSelect(prefix+'_kecamatan'); resetSelect(prefix+'_kelurahan'); }
    if (level === 'district') { resetSelect(prefix+'_kelurahan'); }

    const loadEl   = document.getElementById(loadMap[level]);
    const targetEl = document.getElementById(targetMap[level]);
    if (loadEl) loadEl.style.display = 'flex';
    targetEl.disabled = true;
    targetEl.innerHTML = '<option value="">Memuat...</option>';
    try {
      const data = await (await fetch(urlMap[level])).json();
      targetEl.innerHTML = '<option value="">Pilih...</option>';
      data.forEach(item => {
        const opt = document.createElement('option');
        opt.value = item.code; opt.textContent = item.name;
        targetEl.appendChild(opt);
      });
      targetEl.disabled = false;
    } catch {
      targetEl.innerHTML = '<option value="">Gagal memuat</option>';
    } finally {
      if (loadEl) loadEl.style.display = 'none';
    }
  }

  function resetSelect(id) {
    const el = document.getElementById(id);
    if (!el) return;
    el.innerHTML = '<option value="">Pilih...</option>';
    el.disabled  = true;
  }

  async function loadProvinces(prefix, selectedCode) {
    const loadEl = document.getElementById(prefix + '_loading_provinsi');
    const sel    = document.getElementById(prefix + '_provinsi');
    if (loadEl) loadEl.style.display = 'flex';
    try {
      const data = await (await fetch('/api/provinces')).json();
      sel.innerHTML = '<option value="" disabled>Pilih provinsi</option>';
      data.forEach(p => {
        const opt = document.createElement('option');
        opt.value = p.code; opt.textContent = p.name;
        if (selectedCode && p.code === selectedCode) opt.selected = true;
        sel.appendChild(opt);
      });
    } finally {
      if (loadEl) loadEl.style.display = 'none';
    }
  }

  /* ════ PREVIEW GAMBAR ════ */
  function previewImg(input, imgId, hintId) {
    const file = input.files[0];
    if (!file) return;
    if (file.size > 2 * 1024 * 1024) {
      alert('Ukuran file terlalu besar. Maksimal 2MB.');
      input.value = '';
      return;
    }
    const reader = new FileReader();
    reader.onload = function(e) {
      const img  = document.getElementById(imgId);
      const hint = document.getElementById(hintId);
      img.src = e.target.result; img.style.display = 'block'; hint.style.display = 'none';
    };
    reader.readAsDataURL(file);
  }

  /* ════ MODAL UMUM ════ */
  function openModal(id)  { document.getElementById(id).classList.add('open');    }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }

  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', function(e) {
      if (e.target === this) this.classList.remove('open');
    });
  });

  /* ════ MODAL CREATE ════ */
  document.getElementById('btnTambah').addEventListener('click', () => {
    document.getElementById('createForm').reset();
    const img  = document.getElementById('c_preview_img');
    const hint = document.getElementById('c_upload_hint');
    img.src = ''; img.style.display = 'none'; hint.style.display = 'flex';
    resetSelect('c_kota'); resetSelect('c_kecamatan'); resetSelect('c_kelurahan');
    const today    = new Date().toISOString().split('T')[0];
    const cSelesai = document.getElementById('c_tanggal_selesai');
    if (cSelesai) { cSelesai.min = today; cSelesai.value = ''; }
    openModal('createModal');
    loadProvinces('c', null);
  });

  /* ════ MODAL EDIT ════ */
  let originalMulai = '';
  document.querySelectorAll('.btnEdit').forEach(btn => {
    btn.addEventListener('click', async function () {
      const id   = this.dataset.id;
      const form = document.getElementById('editForm');
      form.action = `/admin-pusat/kelola-program/edit/${id}`;

      document.getElementById('e_judul').value     = this.dataset.judul    || '';
      document.getElementById('e_deskripsi').value = this.dataset.deskripsi || '';
      document.getElementById('e_harga').value     = this.dataset.harga    || '';
      document.getElementById('e_mulai').value     = this.dataset.mulai    || '';
      document.getElementById('e_selesai').value   = this.dataset.selesai  || '';
      originalMulai = this.dataset.mulai || '';

      const eSelesai = document.getElementById('e_selesai');
      const today    = new Date().toISOString().split('T')[0];
      eSelesai.min   = originalMulai || today;

      const img  = document.getElementById('e_preview_img');
      const hint = document.getElementById('e_upload_hint');
      if (this.dataset.flyer) {
        img.src = `/uploads/program/${this.dataset.flyer}`;
        img.style.display = 'block'; hint.style.display = 'none';
      } else {
        img.style.display = 'none'; hint.style.display = 'flex';
      }

      resetSelect('e_kota'); resetSelect('e_kecamatan'); resetSelect('e_kelurahan');
      await loadProvinces('e', this.dataset.provinsi);

      if (this.dataset.provinsi) {
        await loadWilayah('e', 'regency', this.dataset.provinsi);
        document.getElementById('e_kota').value = this.dataset.kota || '';
      }
      if (this.dataset.kota) {
        await loadWilayah('e', 'district', this.dataset.kota);
        document.getElementById('e_kecamatan').value = this.dataset.kecamatan || '';
      }
      if (this.dataset.kecamatan) {
        await loadWilayah('e', 'village', this.dataset.kecamatan);
        document.getElementById('e_kelurahan').value = this.dataset.kelurahan || '';
      }
      openModal('editModal');
    });
  });

  /* ════ MODAL HAPUS ════ */
  let pendingHapusForm = null;
  function confirmHapus(e, nama) {
    e.preventDefault();
    pendingHapusForm = e.target.closest('form');
    document.getElementById('hapusNama').textContent = 'Program "' + nama + '" akan dihapus permanen.';
    openModal('hapusModal');
  }
  document.getElementById('hapusConfirmBtn').addEventListener('click', () => {
    if (pendingHapusForm) pendingHapusForm.submit();
  });

  /* ════ PAGINASI ════ */
  const PER_PAGE = 7;
  let allRows = [], filteredRows = [], currentPage = 1;

  function initRows() {
    allRows      = Array.from(document.querySelectorAll('.data-row'));
    filteredRows = [...allRows];
    renderPage(1);
  }

  function renderPage(page) {
    currentPage = page;
    const total      = filteredRows.length;
    const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;
    const start = (currentPage - 1) * PER_PAGE;
    const end   = start + PER_PAGE;
    allRows.forEach(r => r.style.display = 'none');
    filteredRows.slice(start, end).forEach((r, i) => {
      r.style.display = '';
      r.querySelector('.nomor').innerText = start + i + 1;
    });
    const noResult = document.getElementById('noResultRow');
    if (noResult) noResult.style.display = total === 0 ? '' : 'none';
    renderPaginasi(currentPage, totalPages, total, start, Math.min(end, total));
  }

  function renderPaginasi(page, totalPages, total, start, end) {
    document.getElementById('paginasiInfo').textContent =
      total === 0 ? 'Tidak ada data' : `Menampilkan ${start + 1}–${end} dari ${total} program`;
    const container = document.getElementById('paginasiBtns');
    container.innerHTML = '';
    const prev = document.createElement('button');
    prev.className = 'pg-btn';
    prev.innerHTML = `<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    prev.disabled  = page <= 1;
    prev.onclick   = () => renderPage(page - 1);
    container.appendChild(prev);
    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || (i >= page - 1 && i <= page + 1)) {
        const btn = document.createElement('button');
        btn.className   = 'pg-btn' + (i === page ? ' active' : '');
        btn.textContent = i;
        btn.onclick     = () => renderPage(i);
        container.appendChild(btn);
      } else if (i === page - 2 || i === page + 2) {
        const dots = document.createElement('span');
        dots.textContent  = '…';
        dots.style.cssText = 'color:#aac8b4; font-size:.8rem; padding:0 4px; align-self:center';
        container.appendChild(dots);
      }
    }
    const next = document.createElement('button');
    next.className = 'pg-btn';
    next.innerHTML = `<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    next.disabled  = page >= totalPages;
    next.onclick   = () => renderPage(page + 1);
    container.appendChild(next);
  }

  /* ════ FILTER POPUP ════ */
  function toggleFilterPopup(e) {
    e.stopPropagation();
    const popup = document.getElementById('filterPopup');
    const isOpen = popup.style.display === 'block';
    if (isOpen) {
      popup.style.display = 'none';
    } else {
      popup.style.display = 'block';
      populateFilterOptions();
    }
  }

  function closeFilterPopup() {
    document.getElementById('filterPopup').style.display = 'none';
  }

  /* Tutup popup saat klik di luar */
  document.addEventListener('click', function(e) {
    const popup  = document.getElementById('filterPopup');
    const toggle = document.getElementById('btnFilterToggle');
    if (!popup || popup.style.display !== 'block') return;
    if (popup.contains(e.target) || toggle.contains(e.target)) return;
    popup.style.display = 'none';
  });

  /* ════ OPSI FILTER DARI DATA TABEL ════ */
  let _wilayahReady = false;
  function populateFilterOptions() {
    if (_wilayahReady) return;
    _wilayahReady = true;

    const provinsiMap = new Map();
    const kotaByProv  = new Map();

    allRows.forEach(row => {
      const btn   = row.querySelector('.btnEdit');
      if (!btn) return;
      const pCode = btn.dataset.provinsi;
      const kCode = btn.dataset.kota;
      const wilEl = row.querySelector('.wilayah-cell-text span');
      if (!wilEl || wilEl.style.fontStyle === 'italic' || !pCode) return;

      const parts        = wilEl.textContent.split(',').map(s => s.trim());
      const namaProvinsi = parts[parts.length - 1];
      const namaKota     = parts.length >= 3 ? parts[parts.length - 2] : null;

      if (namaProvinsi) provinsiMap.set(pCode, namaProvinsi);
      if (kCode && namaKota) {
        if (!kotaByProv.has(pCode)) kotaByProv.set(pCode, new Map());
        kotaByProv.get(pCode).set(kCode, namaKota);
      }
    });

    window._kotaByProv = kotaByProv;
    const selProv = document.getElementById('filterProvinsi');
    selProv.innerHTML = '<option value="">Semua provinsi</option>';
    [...provinsiMap.entries()]
      .sort((a, b) => a[1].localeCompare(b[1], 'id'))
      .forEach(([code, name]) => {
        const o = document.createElement('option');
        o.value = code; o.textContent = name;
        selProv.appendChild(o);
      });
  }

  function onFilterProvinsiChange() {
    const pCode   = document.getElementById('filterProvinsi').value;
    const selKota = document.getElementById('filterKota');
    selKota.innerHTML = '<option value="">Semua kab/kota</option>';
    if (pCode && window._kotaByProv && window._kotaByProv.has(pCode)) {
      [...window._kotaByProv.get(pCode).entries()]
        .sort((a, b) => a[1].localeCompare(b[1], 'id'))
        .forEach(([code, name]) => {
          const o = document.createElement('option');
          o.value = code; o.textContent = name;
          selKota.appendChild(o);
        });
      selKota.disabled = false;
    } else {
      selKota.disabled = true;
    }
  }

  /* ════ APPLY / RESET FILTER ════ */
  function applyFilters() {
    const keyword = document.getElementById('searchInput').value.toLowerCase();
    const pCode   = document.getElementById('filterProvinsi').value;
    const kCode   = document.getElementById('filterKota').value;

    filteredRows = allRows.filter(row => {
      const btn = row.querySelector('.btnEdit');
      return (
        (!keyword || row.querySelector('.judul').innerText.toLowerCase().includes(keyword)) &&
        (!pCode   || (btn && btn.dataset.provinsi === pCode)) &&
        (!kCode   || (btn && btn.dataset.kota     === kCode))
      );
    });
    updateChips();
    renderPage(1);
  }

  function resetFilters() {
    document.getElementById('filterProvinsi').value = '';
    document.getElementById('filterKota').innerHTML = '<option value="">Semua kab/kota</option>';
    document.getElementById('filterKota').disabled  = true;
    document.getElementById('searchInput').value    = '';
    filteredRows = [...allRows];
    updateChips();
    renderPage(1);
  }

  function resetProvinsiFilter() {
    document.getElementById('filterProvinsi').value = '';
    onFilterProvinsiChange();
    applyFilters();
  }

  function resetKotaFilter() {
    document.getElementById('filterKota').value = '';
    applyFilters();
  }

  /* ════ UPDATE CHIP + DOT ════ */
  function updateChips() {
    const hasProv = !!document.getElementById('filterProvinsi').value;
    const hasKota = !!document.getElementById('filterKota').value;
    const hasAny  = hasProv || hasKota;

    /* Dot + warna icon */
    document.getElementById('filterDot').style.display = hasAny ? 'block' : 'none';
    const btn = document.getElementById('btnFilterToggle');
    if (hasAny) btn.classList.add('active'); else btn.classList.remove('active');

    /* Chips bar */
    const chipsBar = document.getElementById('filterChips');
    chipsBar.style.display = hasAny ? 'flex' : 'none';

    const selProv    = document.getElementById('filterProvinsi');
    const cpProv     = document.getElementById('chipProvinsi');
    const cpProvText = document.getElementById('chipProvinsiText');
    if (hasProv) {
      cpProvText.textContent  = selProv.options[selProv.selectedIndex].textContent;
      cpProv.style.display    = 'inline-flex';
    } else {
      cpProv.style.display    = 'none';
    }

    const selKota    = document.getElementById('filterKota');
    const cpKota     = document.getElementById('chipKota');
    const cpKotaText = document.getElementById('chipKotaText');
    if (hasKota) {
      cpKotaText.textContent  = selKota.options[selKota.selectedIndex].textContent;
      cpKota.style.display    = 'inline-flex';
    } else {
      cpKota.style.display    = 'none';
    }
  }

  /* ════ SEARCH ════ */
  document.getElementById('searchInput').addEventListener('keyup', applyFilters);

  /* ════ VALIDASI FORM ════ */
  document.getElementById('createForm').addEventListener('submit', function(e) {
    const today   = new Date().toISOString().split('T')[0];
    const judul   = this.judul_program.value.trim();
    const harga   = this.harga_pohon.value;
    const mulai   = this.tanggal_mulai.value;
    const selesai = this.tanggal_selesai.value;
    const msg     = document.getElementById('createValidasi');

    if (!judul || !harga || !mulai || !selesai) {
      e.preventDefault(); msg.style.display = 'block';
      msg.textContent = 'Silahkan lengkapi semua data yang wajib diisi'; return;
    }
    if (selesai < today) {
      e.preventDefault(); msg.style.display = 'block';
      msg.textContent = 'Tanggal selesai tidak boleh sebelum hari ini'; return;
    }
    if (selesai < mulai) {
      e.preventDefault(); msg.style.display = 'block';
      msg.textContent = 'Tanggal selesai tidak boleh sebelum tanggal mulai'; return;
    }
    msg.style.display = 'none';
  });

  document.getElementById('editForm').addEventListener('submit', function(e) {
    const today   = new Date().toISOString().split('T')[0];
    const judul   = document.getElementById('e_judul').value.trim();
    const harga   = document.getElementById('e_harga').value;
    const mulai   = document.getElementById('e_mulai').value;
    const selesai = document.getElementById('e_selesai').value;
    const msg     = document.getElementById('editValidasi');

    if (!judul || !harga || !mulai || !selesai) {
      e.preventDefault(); msg.style.display = 'block';
      msg.textContent = 'Silahkan lengkapi semua data yang wajib diisi'; return;
    }
    if (mulai !== originalMulai) {
      e.preventDefault(); msg.style.display = 'block';
      msg.textContent = 'Tanggal mulai tidak dapat diubah'; return;
    }
    if (selesai < today) {
      e.preventDefault(); msg.style.display = 'block';
      msg.textContent = 'Tanggal selesai tidak boleh sebelum hari ini'; return;
    }
    if (selesai < mulai) {
      e.preventDefault(); msg.style.display = 'block';
      msg.textContent = 'Tanggal selesai tidak boleh sebelum tanggal mulai'; return;
    }
    msg.style.display = 'none';
  });

  document.querySelectorAll('.mform-input').forEach(el => {
    el.addEventListener('input',  () => {
      document.getElementById('createValidasi').style.display = 'none';
      document.getElementById('editValidasi').style.display   = 'none';
    });
    el.addEventListener('change', () => {
      document.getElementById('createValidasi').style.display = 'none';
      document.getElementById('editValidasi').style.display   = 'none';
    });
  });

  /* ── Init ── */
  setDateMin();
  initRows();
</script>
