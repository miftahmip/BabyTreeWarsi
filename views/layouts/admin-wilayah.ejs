<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — BabyTree' : 'BabyTree' %></title>
  <link href="/output.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --green-deep:   #1a4731;
      --green-mid:    #2d6a4f;
      --green-bright: #40916c;
      --green-light:  #74c69d;
      --green-pale:   #d8f3dc;
      --green-ghost:  #f0faf4;
      --brown-mid:    #7d5a3c;
      --brown-light:  #c9a87c;
      --cream:        #fdf8f0;
      --sidebar-w:    240px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      display: flex;
      height: 100vh;
      overflow: hidden;
    }

    aside.sidebar {
      width: var(--sidebar-w);
      min-width: var(--sidebar-w);
      background: var(--green-deep);
      display: flex;
      flex-direction: column;
      height: 100vh;
      position: relative;
      z-index: 20;
      box-shadow: 4px 0 24px rgba(26,71,49,0.18);
    }

    .sidebar-logo {
      padding: 24px 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .sidebar-logo img {
      width: 200px;
      height: 90px;
      object-fit: contain;
      background: #fdf8f0;
      border-radius: 5px;
      padding: 4px 6px;
    }

    nav.sidebar-nav {
      flex: 1;
      padding: 16px 12px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      overflow-y: auto;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 11px;
      padding: 12px 12px;
      border-radius: 10px;
      text-decoration: none;
      color: rgba(255,255,255,0.90);
      font-size: .875rem;
      font-weight: 400;
      transition: background .2s, color .2s;
      position: relative;
    }
    .nav-item:hover {
      background: rgba(255,255,255,0.07);
      color: #fff;
    }
    .nav-item.active {
      background: #ffffff;
      color: var(--green-deep);
      font-weight: 600;
    }
    .nav-item.active svg {
      opacity: 1;
      color: var(--green-deep);
    }
    .nav-item svg {
      flex-shrink: 0;
      opacity: .85;
    }
    .nav-item:hover svg { opacity: 1; }

    .sidebar-footer {
      padding: 16px 12px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .sidebar-role-badge {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 10px;
      border-radius: 10px;
      background: rgba(255,255,255,0.05);
    }
    .role-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--green-light);
      flex-shrink: 0;
    }
    .role-text {
      font-size: .72rem;
      color: rgba(255,255,255,0.45);
      letter-spacing: .3px;
    }

    .topbar {
      height: 64px;
      background: rgba(253,248,240,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(116,198,157,0.2);
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 0 28px;
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .profile-wrap { position: relative; }
    .profile-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 6px 12px 6px 6px;
      border-radius: 40px;
      border: 1.5px solid rgba(116,198,157,0.35);
      background: rgba(216,243,220,0.2);
      cursor: pointer;
      transition: background .2s, border-color .2s;
      user-select: none;
    }
    .profile-btn:hover {
      background: rgba(216,243,220,0.45);
      border-color: rgba(116,198,157,0.55);
    }
    .profile-avatar {
      width: 34px; height: 34px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--green-bright), var(--green-deep));
      display: flex; align-items: center; justify-content: center;
      font-size: .78rem;
      font-weight: 600;
      color: #fff;
      flex-shrink: 0;
    }
    .profile-info .p-name {
      font-size: .82rem;
      font-weight: 600;
      color: var(--green-deep);
      line-height: 1.1;
    }
    .chevron {
      color: var(--green-bright);
      transition: transform .2s;
    }
    .profile-wrap.open .chevron { transform: rotate(180deg); }

    .dropdown-menu {
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      min-width: 180px;
      background: #fff;
      border: 1px solid rgba(116,198,157,0.25);
      border-radius: 14px;
      box-shadow: 0 8px 32px rgba(26,71,49,0.14);
      padding: 6px;
      opacity: 0;
      transform: translateY(-6px) scale(.97);
      pointer-events: none;
      transition: opacity .2s, transform .2s;
      z-index: 50;
    }
    .profile-wrap.open .dropdown-menu {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: all;
    }
    .dropdown-menu a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border-radius: 9px;
      text-decoration: none;
      font-size: .85rem;
      color: var(--green-deep);
      font-weight: 400;
      transition: background .15s;
    }
    .dropdown-menu a:hover { background: var(--green-ghost); }
    .dropdown-menu a.danger { color: #b03030; }
    .dropdown-menu a.danger:hover { background: #fff4f4; }
    .dropdown-divider {
      height: 1px;
      background: rgba(116,198,157,0.18);
      margin: 5px 6px;
    }

    .layout-shell {
      display: flex;
      flex: 1;
      overflow: hidden;
    }
    .main-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    main.content {
      flex: 1;
      overflow-y: auto;
      padding: 28px 32px;
      background: var(--cream);
    }
  </style>
</head>
<body>

<div class="layout-shell">

  <!-- SIDEBAR -->
  <aside class="sidebar">

    <!-- Logo -->
    <div class="sidebar-logo">
      <img src="/images/warsi_logo.png" alt="BabyTree Logo" />
    </div>

    <!-- Navigation -->
    <nav class="sidebar-nav">

      <!-- Dashboard -->
      <a href="/dashboard/admin-wilayah"
        class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <rect x="3" y="3" width="7" height="7" rx="1.5"></rect>
          <rect x="14" y="3" width="7" height="7" rx="1.5"></rect>
          <rect x="3" y="14" width="7" height="7" rx="1.5"></rect>
          <rect x="14" y="14" width="7" height="7" rx="1.5"></rect>
        </svg>
        Dashboard
      </a>

      <!-- Penanaman -->
      <a href="/admin-wilayah/penanaman"
        class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'penanaman' ? 'active' : '' %>">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" stroke-linecap="round"></path>
          <rect x="9" y="3" width="6" height="4" rx="1.5"></rect>
          <path d="M9 12h6M9 16h4" stroke-linecap="round"></path>
        </svg>
        Penugasan
      </a>

      <!-- Data Pohon -->
      <a href="/admin-wilayah/jenis-pohon"
        class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'jenis-pohon' ? 'active' : '' %>">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <polygon points="12,2 7,9 17,9" stroke-linejoin="round"></polygon>
          <polygon points="12,6 5.5,14 18.5,14" stroke-linejoin="round"></polygon>
          <polygon points="12,10 4,20 20,20" stroke-linejoin="round"></polygon>
          <line x1="12" y1="20" x2="12" y2="22" stroke-linecap="round"></line>
        </svg>
        Pohon
      </a>

      <!-- Verifikasi -->
      <a href="/admin-wilayah/verifikasi-pohon"
        class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'verifikasi' ? 'active' : '' %>">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <circle cx="12" cy="12" r="9"></circle>
          <path d="M8.5 12.5l2.5 2.5 4.5-5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        Verifikasi
      </a>

      <!-- Rekap Pembayaran -->
      <a href="/admin-wilayah/rekap-pembayaran"
        class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'rekap-pembayaran' ? 'active' : '' %>">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <rect x="2" y="5" width="20" height="14" rx="2"></rect>
          <path d="M2 10h20" stroke-linecap="round"></path>
          <path d="M6 15h4M14 15h4" stroke-linecap="round"></path>
        </svg>
        Rekap Pembayaran
      </a>

    </nav>

    <!-- Footer badge -->
    <div class="sidebar-footer">
      <div class="sidebar-role-badge">
        <div class="role-dot"></div>
        <span class="role-text">Admin Wilayah</span>
      </div>
    </div>

  </aside>

  <!-- MAIN WRAP -->
  <div class="main-wrap">

    <!-- Topbar -->
    <header class="topbar">
      <div class="topbar-right">

        <!-- Profile Dropdown -->
        <div class="profile-wrap" id="profileWrap">
          <div class="profile-btn" onclick="toggleDropdown()">

            <div class="profile-avatar">
              <%= user.nama_lengkap.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase() %>
            </div>

            <div class="profile-info">
              <div class="p-name"><%= user.nama_lengkap %></div>
            </div>

            <svg class="chevron" width="14" height="14" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2.5">
              <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>

          <!-- Dropdown -->
          <div class="dropdown-menu">
            <a href="/profil">
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="8" r="4"></circle>
                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke-linecap="round"></path>
              </svg>
              Profil Saya
            </a>
            <div class="dropdown-divider"></div>
            <a href="/logout" class="danger">
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M17 16l4-4m0 0l-4-4m4 4H7" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M3 12v7a2 2 0 0 0 2 2h6" stroke-linecap="round"></path>
              </svg>
              Logout
            </a>
          </div>
        </div>

      </div>
    </header>

    <!-- Konten halaman -->
    <main class="content">
      <%- body %>
    </main>

  </div>

</div>

<script>
  function toggleDropdown() {
    document.getElementById('profileWrap').classList.toggle('open');
  }
  document.addEventListener('click', function(e) {
    const wrap = document.getElementById('profileWrap');
    if (!wrap.contains(e.target)) wrap.classList.remove('open');
  });
</script>
</body>
</html>