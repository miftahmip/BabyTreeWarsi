<script>

  /* ════ TAB SWITCH ════ */
  function switchTab(name, btn) {
    document.querySelectorAll('.dv-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.dv-tab').forEach(b => b.classList.remove('active'));
    document.getElementById('panel-' + name).classList.add('active');
    btn.classList.add('active');
  }


  /* ════ PAGINATION (generic) ════ */
  const PER_PAGE = 10;

  function initPagination(rowClass, infoId, btnsId, pageRef) {
    const rows = Array.from(document.querySelectorAll('.' + rowClass));
    renderPage(rows, 1, infoId, btnsId, pageRef);
  }

  function renderPage(rows, page, infoId, btnsId, pageRef) {
    pageRef.cur = page;
    const total      = rows.length;
    const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    if (pageRef.cur > totalPages) pageRef.cur = totalPages;

    const start = (pageRef.cur - 1) * PER_PAGE;
    const end   = start + PER_PAGE;

    rows.forEach((r, i) => {
      r.style.display = (i >= start && i < end) ? '' : 'none';
    });

    const infoEl = document.getElementById(infoId);
    infoEl.textContent = total === 0
      ? 'Tidak ada data'
      : `Menampilkan ${start + 1}–${Math.min(end, total)} dari ${total} data`;

    const btns = document.getElementById(btnsId);
    btns.innerHTML = '';

    const mkBtn = (label, onClick, disabled, active) => {
      const b = document.createElement('button');
      b.type      = 'button';
      b.className = 'dv-pg-btn' + (active ? ' active' : '');
      b.disabled  = disabled;
      if (typeof label === 'number') b.textContent = label;
      else b.innerHTML = label;
      b.addEventListener('click', onClick);
      return b;
    };

    const chevL = `<svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    const chevR = `<svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

    btns.appendChild(mkBtn(chevL, () => renderPage(rows, pageRef.cur - 1, infoId, btnsId, pageRef), pageRef.cur <= 1));

    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || (i >= pageRef.cur - 1 && i <= pageRef.cur + 1)) {
        btns.appendChild(mkBtn(i, () => renderPage(rows, i, infoId, btnsId, pageRef), false, i === pageRef.cur));
      } else if (i === pageRef.cur - 2 || i === pageRef.cur + 2) {
        const dots = document.createElement('span');
        dots.textContent = '…';
        dots.style.cssText = 'color:#aac8b4;font-size:.78rem;padding:0 3px;align-self:center';
        btns.appendChild(dots);
      }
    }

    btns.appendChild(mkBtn(chevR, () => renderPage(rows, pageRef.cur + 1, infoId, btnsId, pageRef), pageRef.cur >= totalPages));
  }


  /* ════ CHECKBOX – PENANAMAN ════ */
  const checkAll   = document.getElementById('checkAll');
  const checkboxes = document.querySelectorAll('.checkbox-item');

  checkAll.addEventListener('change', function() {
    document.querySelectorAll('.dv-row:not([style*="none"]) .checkbox-item:not(:disabled)')
      .forEach(cb => { cb.checked = this.checked; });
    updateCount();
  });

  function updateCount() {
    const checked = document.querySelectorAll('.checkbox-item:checked');
    const total   = document.querySelectorAll('.checkbox-item:not(:disabled)').length;
    const n       = checked.length;

    checkAll.indeterminate = n > 0 && n < total;
    checkAll.checked       = total > 0 && n === total;

    const bar = document.getElementById('actionBar');
    if (n > 0) {
      bar.classList.add('visible');
      document.getElementById('actionBarInfo').textContent = n + ' pohon dipilih';
    } else {
      bar.classList.remove('visible');
    }
  }


  /* ════ CHECKBOX – MONITORING PANELS (generic) ════ */
  function checkAllPanel(key, masterCb) {
    const cbClass  = key + '-cb';
    const rowClass = key + '-row';

    document.querySelectorAll('.' + rowClass + ':not([style*="none"]) .' + cbClass + ':not(:disabled)')
      .forEach(cb => { cb.checked = masterCb.checked; });

    updateCountPanel(key);
  }

  function updateCountPanel(key) {
    const cbClass  = '.' + key + '-cb';
    const checked  = document.querySelectorAll(cbClass + ':checked');
    const total    = document.querySelectorAll(cbClass + ':not(:disabled)').length;
    const n        = checked.length;

    const masterCb = document.getElementById('checkAll-' + key);
    if (masterCb) {
      masterCb.indeterminate = n > 0 && n < total;
      masterCb.checked       = total > 0 && n === total;
    }

    const bar     = document.getElementById('actionBar-' + key);
    const infoEl  = document.getElementById('actionBarInfo-' + key);

    if (n > 0) {
      bar.classList.add('visible');
      infoEl.textContent = n + ' data dipilih';
    } else {
      bar.classList.remove('visible');
    }
  }


  /* ════ MODAL REVISI ════ */
  /*
    context: 'penanaman' | 'monitoring1' | 'monitoring2' | 'monitoring3'
  */
  function openRevisiModal(context) {

    let selectedItems = [];
    let formAction    = '';
    let inputName     = '';
    let periodeVal    = '';

    if (context === 'penanaman') {
      selectedItems = Array.from(document.querySelectorAll('.checkbox-item:checked'));
      formAction    = '/admin-wilayah/verifikasi-pohon/revisi';
      inputName     = 'selected_pohon';
    } else if (context === 'monitoring1') {
      selectedItems = Array.from(document.querySelectorAll('.mon1-cb:checked'));
      formAction    = '/admin-wilayah/verifikasi-monitoring/revisi';
      inputName     = 'selected_monitoring';
      periodeVal    = '1';
    } else if (context === 'monitoring2') {
      selectedItems = Array.from(document.querySelectorAll('.mon2-cb:checked'));
      formAction    = '/admin-wilayah/verifikasi-monitoring/revisi';
      inputName     = 'selected_monitoring';
      periodeVal    = '2';
    } else if (context === 'monitoring3') {
      selectedItems = Array.from(document.querySelectorAll('.mon3-cb:checked'));
      formAction    = '/admin-wilayah/verifikasi-monitoring/revisi';
      inputName     = 'selected_monitoring';
      periodeVal    = '3';
    }

    if (selectedItems.length === 0) {
      alert('Pilih minimal 1 data terlebih dahulu');
      return;
    }

    // Set form action & periode
    const form = document.getElementById('formRevisi');
    form.action = formAction;
    document.getElementById('revisiPeriode').value = periodeVal;

    // Inject hidden selected inputs
    const container = document.getElementById('selectedContainer');
    container.innerHTML = '';
    selectedItems.forEach(item => {
      const inp = document.createElement('input');
      inp.type  = 'hidden';
      inp.name  = inputName;
      inp.value = item.value;
      container.appendChild(inp);
    });

    document.getElementById('modalRevisi').classList.add('open');
  }

  function closeRevisiModal() {
    document.getElementById('modalRevisi').classList.remove('open');
  }

  document.getElementById('modalRevisi').addEventListener('click', function(e) {
    if (e.target === this) closeRevisiModal();
  });


  /* ════ INIT PAGINATION ════ */
  const pgPenanaman  = { cur: 1 };
  const pgMon1       = { cur: 1 };
  const pgMon2       = { cur: 1 };
  const pgMon3       = { cur: 1 };

  (function init() {
    const rowsPenanaman = Array.from(document.querySelectorAll('.dv-row'));
    const rowsMon1      = Array.from(document.querySelectorAll('.mon1-row'));
    const rowsMon2      = Array.from(document.querySelectorAll('.mon2-row'));
    const rowsMon3      = Array.from(document.querySelectorAll('.mon3-row'));

    renderPage(rowsPenanaman, 1, 'dvPgInfo',   'dvPgBtns',   pgPenanaman);
    renderPage(rowsMon1,      1, 'mon1PgInfo', 'mon1PgBtns', pgMon1);
    renderPage(rowsMon2,      1, 'mon2PgInfo', 'mon2PgBtns', pgMon2);
    renderPage(rowsMon3,      1, 'mon3PgInfo', 'mon3PgBtns', pgMon3);
  })();

</script>
