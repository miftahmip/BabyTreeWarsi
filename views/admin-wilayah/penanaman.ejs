<script>
  /* ════ STATE PETUGAS ════ */
  // Menyimpan petugas yang dipilih per prefix (c = create, e = edit)
  const selectedPetugas = { c: {}, e: {} };

  function togglePetugasDropdown(prefix) {
    const list    = document.getElementById(prefix + '_petugasList');
    const trigger = document.getElementById(prefix + '_petugasTrigger');
    list.classList.toggle('open');
    trigger.classList.toggle('open');
  }

  function togglePetugasOption(prefix, id, nama) {
    const cb = document.getElementById(prefix + '_cb_' + id);
    cb.checked = !cb.checked;

    if (cb.checked) {
      selectedPetugas[prefix][id] = nama;
    } else {
      delete selectedPetugas[prefix][id];
    }
    renderPetugasTags(prefix);
    renderPetugasHidden(prefix);
    updateTriggerText(prefix);
  }

  function renderPetugasTags(prefix) {
    const container = document.getElementById(prefix + '_petugasTags');
    container.innerHTML = '';
    Object.entries(selectedPetugas[prefix]).forEach(([id, nama]) => {
      const tag = document.createElement('div');
      tag.className = 'petugas-tag';
      tag.innerHTML = `
        ${nama}
        <button type="button" class="petugas-tag-remove"
                onclick="removePetugas('${prefix}','${id}')">✕</button>
      `;
      container.appendChild(tag);
    });
  }

  function renderPetugasHidden(prefix) {
    const container = document.getElementById(prefix + '_petugasHidden');
    container.innerHTML = '';
    Object.keys(selectedPetugas[prefix]).forEach(id => {
      const inp = document.createElement('input');
      inp.type = 'hidden';
      inp.name = 'petugas';
      inp.value = id;
      container.appendChild(inp);
    });
  }

  function updateTriggerText(prefix) {
    const text  = document.getElementById(prefix + '_petugasText');
    const count = Object.keys(selectedPetugas[prefix]).length;
    if (count === 0) {
      text.textContent = 'Pilih petugas lapangan';
      text.classList.remove('has-value');
    } else {
      text.textContent = count + ' petugas dipilih';
      text.classList.add('has-value');
    }
  }

  function removePetugas(prefix, id) {
    delete selectedPetugas[prefix][id];
    const cb = document.getElementById(prefix + '_cb_' + id);
    if (cb) cb.checked = false;
    renderPetugasTags(prefix);
    renderPetugasHidden(prefix);
    updateTriggerText(prefix);
  }

  // Tutup dropdown petugas jika klik di luar
  document.addEventListener('click', function(e) {
    ['c', 'e'].forEach(prefix => {
      const dropdown = document.getElementById(prefix + '_petugasDropdown');
      const list     = document.getElementById(prefix + '_petugasList');
      const trigger  = document.getElementById(prefix + '_petugasTrigger');
      if (dropdown && !dropdown.contains(e.target)) {
        list?.classList.remove('open');
        trigger?.classList.remove('open');
      }
    });
  });

  /* ════ MODAL ════ */
  function openModal(id)  { document.getElementById(id).classList.add('open');    }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }

  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', function(e) {
      if (e.target === this) this.classList.remove('open');
    });
  });

  // Reset create modal saat ditutup
  document.querySelector('[onclick="closeModal(\'createModal\')"]')
    .addEventListener('click', () => resetPetugas('c'));

  function resetPetugas(prefix) {
    selectedPetugas[prefix] = {};
    renderPetugasTags(prefix);
    renderPetugasHidden(prefix);
    updateTriggerText(prefix);
    document.querySelectorAll('[id^="' + prefix + '_cb_"]').forEach(cb => cb.checked = false);
  }

  /* ════ EDIT BUTTON ════ */
  document.querySelectorAll('.btnEdit').forEach(btn => {
    btn.addEventListener('click', function() {
      const d = this.dataset;

      document.getElementById('e_program').value  = d.program;
      document.getElementById('e_tanggal').value  = d.tanggal;
      document.getElementById('e_tanggal_selesai').value = d.tanggalSelesai || '';
      document.getElementById('e_status').value   = d.status;
      document.getElementById('editForm').action  =
        '/admin-wilayah/penanaman/update/' + d.id;

      // Reset dulu
      resetPetugas('e');

      // Set petugas yang sudah dipilih
      if (d.petugas && d.petugas.trim() !== '') {
        const ids = d.petugas.split(',');
        ids.forEach(id => {
          id = id.trim();
          const cb = document.getElementById('e_cb_' + id);
          if (cb) {
            cb.checked = true;
            selectedPetugas['e'][id] = cb.dataset.nama;
          }
        });
        renderPetugasTags('e');
        renderPetugasHidden('e');
        updateTriggerText('e');
      }

      openModal('editModal');
    });
  });

  /* ════ KONFIRMASI HAPUS ════ */
  let pendingHapusForm = null;

  function confirmHapus(e, id) {
    e.preventDefault();
    pendingHapusForm = e.target.closest('form');
    document.getElementById('hapusDesc').textContent =
      'Data ini akan dihapus permanen dan tidak dapat dikembalikan.';
    openModal('hapusModal');
  }

  document.getElementById('hapusConfirmBtn').addEventListener('click', () => {
    if (pendingHapusForm) pendingHapusForm.submit();
  });

  /* ════ VALIDASI ════ */
  document.getElementById('createForm').addEventListener('submit', function(e) {
    const program = this.id_program.value;
    const tgl     = this.tanggal_mulai.value;
    const msg     = document.getElementById('createValidasi');
    if (!program || !tgl) {
      e.preventDefault();
      msg.style.display = 'block';
      msg.textContent   = 'Silahkan lengkapi data';
    } else {
      msg.style.display = 'none';
    }
  });

  document.getElementById('editForm').addEventListener('submit', function(e) {
    const program = document.getElementById('e_program').value;
    const tgl     = document.getElementById('e_tanggal').value;
    const tglSelesai    = document.getElementById('e_tanggal_selesai').value; //
    const msg     = document.getElementById('editValidasi');
    if (!program || !tgl) {
      e.preventDefault();
      msg.style.display = 'block';
      msg.textContent   = 'Silahkan lengkapi data';
    } else {
      msg.style.display = 'none';
    }
  });

  /* ════ PAGINASI ════ */
  const PER_PAGE = 7;
  let allRows = [], filteredRows = [], currentPage = 1;

  function initRows() {
    allRows      = Array.from(document.querySelectorAll('.data-row'));
    filteredRows = [...allRows];
    renderPage(1);
  }

  function renderPage(page) {
    currentPage = page;
    const total      = filteredRows.length;
    const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;
    const start = (currentPage - 1) * PER_PAGE;
    const end   = start + PER_PAGE;
    allRows.forEach(r => r.style.display = 'none');
    filteredRows.slice(start, end).forEach((r, i) => {
      r.style.display = '';
      r.querySelector('.nomor').innerText = start + i + 1;
    });
    const noResult = document.getElementById('noResultRow');
    if (noResult) noResult.style.display = total === 0 ? '' : 'none';
    renderPaginasi(currentPage, totalPages, total, start, Math.min(end, total));
  }

  function renderPaginasi(page, totalPages, total, start, end) {
    document.getElementById('paginasiInfo').textContent =
      total === 0 ? 'Tidak ada data' :
      `Menampilkan ${start + 1}–${end} dari ${total} penanaman`;

    const container = document.getElementById('paginasiBtns');
    container.innerHTML = '';

    const prev = document.createElement('button');
    prev.className = 'pg-btn';
    prev.innerHTML = `<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    prev.disabled = page <= 1;
    prev.onclick  = () => renderPage(page - 1);
    container.appendChild(prev);

    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || (i >= page - 1 && i <= page + 1)) {
        const btn = document.createElement('button');
        btn.className   = 'pg-btn' + (i === page ? ' active' : '');
        btn.textContent = i;
        btn.onclick     = () => renderPage(i);
        container.appendChild(btn);
      } else if (i === page - 2 || i === page + 2) {
        const dots = document.createElement('span');
        dots.textContent = '…';
        dots.style.cssText = 'color:#aac8b4; font-size:.8rem; padding:0 4px; align-self:center';
        container.appendChild(dots);
      }
    }

    const next = document.createElement('button');
    next.className = 'pg-btn';
    next.innerHTML = `<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    next.disabled = page >= totalPages;
    next.onclick  = () => renderPage(page + 1);
    container.appendChild(next);
  }

  /* ════ SEARCH ════ */
  document.getElementById('searchInput').addEventListener('keyup', function() {
    const keyword = this.value.toLowerCase();
    filteredRows = allRows.filter(row => {
      const program = row.querySelector('.program-col').innerText.toLowerCase();
      const petugas = row.querySelector('.petugas-col').innerText.toLowerCase();
      return program.includes(keyword) || petugas.includes(keyword);
    });
    renderPage(1);
  });

  /* ════ MODAL HARGA ════ */
let currentPenanamanId = null;

document.querySelectorAll('.btnHarga').forEach(btn => {
  btn.addEventListener('click', async function () {
    const id      = this.dataset.id;
    const program = this.dataset.program;
    currentPenanamanId = id;

    // reset form
    document.getElementById('h_penanaman').value = '';
    document.getElementById('h_mon1').value       = '';
    document.getElementById('h_mon2').value       = '';
    document.getElementById('h_mon3').value       = '';
    document.getElementById('hargaTotalPreview').textContent = 'Rp 0';
    document.getElementById('hargaValidasi').style.display   = 'none';
    document.getElementById('hargaProgram').textContent      = program;
    document.getElementById('hargaForm').action =
      '/admin-wilayah/harga-penanaman/upsert/' + id;

    // Tampilkan loading
    document.getElementById('hargaLoading').style.display      = 'block';
    document.getElementById('hargaFormFields').style.display   = 'none';
    openModal('hargaModal');

    // Fetch data harga existing
    try {
      const res  = await fetch('/admin-wilayah/harga-penanaman/data/' + id);
      const json = await res.json();
      if (json.success && json.data) {
        const map = {};
        json.data.forEach(d => { map[d.tahap] = d.harga_per_pohon; });
        if (map.penanaman    !== undefined) document.getElementById('h_penanaman').value = map.penanaman;
        if (map.monitoring_1 !== undefined) document.getElementById('h_mon1').value       = map.monitoring_1;
        if (map.monitoring_2 !== undefined) document.getElementById('h_mon2').value       = map.monitoring_2;
        if (map.monitoring_3 !== undefined) document.getElementById('h_mon3').value       = map.monitoring_3;
        hitungTotal();
      }
    } catch (err) {
      console.log('Gagal fetch harga:', err);
    }

    document.getElementById('hargaLoading').style.display    = 'none';
    document.getElementById('hargaFormFields').style.display = 'block';
  });
});

// Hitung total realtime
function hitungTotal() {
  const vals = [
    document.getElementById('h_penanaman').value,
    document.getElementById('h_mon1').value,
    document.getElementById('h_mon2').value,
    document.getElementById('h_mon3').value,
  ];
  const total = vals.reduce((sum, v) => sum + (parseInt(v) || 0), 0);
  document.getElementById('hargaTotalPreview').textContent =
    'Rp ' + total.toLocaleString('id-ID');
}

['h_penanaman','h_mon1','h_mon2','h_mon3'].forEach(id => {
  document.getElementById(id).addEventListener('input', hitungTotal);
});

// Submit harga via AJAX
document.getElementById('hargaForm').addEventListener('submit', async function (e) {
  e.preventDefault();
  const msg     = document.getElementById('hargaValidasi');
  const btn     = document.getElementById('hargaSubmitBtn');
  const fields  = ['h_penanaman','h_mon1','h_mon2','h_mon3'];
  const allFill = fields.every(id => document.getElementById(id).value !== '');

  if (!allFill) {
    msg.textContent   = 'Semua harga tahap wajib diisi';
    msg.style.display = 'block';
    return;
  }

  msg.style.display = 'none';
  btn.disabled      = true;
  btn.textContent   = 'Menyimpan...';

  try {
    const formData = new FormData(this);
    const res      = await fetch(this.action, {
      method: 'POST',
      body: new URLSearchParams(formData)
    });

    // Controller redirect → jika 200/302 dianggap sukses
    if (res.ok || res.redirected) {
      closeModal('hargaModal');
      // Tampilkan notifikasi sukses singkat
      showToast('Harga berhasil disimpan');
    } else {
      throw new Error('Gagal menyimpan');
    }
  } catch (err) {
    msg.textContent   = 'Terjadi kesalahan, coba lagi';
    msg.style.display = 'block';
  } finally {
    btn.disabled    = false;
    btn.textContent = 'Simpan Harga';
  }
});

function showToast(pesan) {
  const toast = document.createElement('div');
  toast.textContent = '✓ ' + pesan;
  toast.style.cssText = `
    position:fixed; bottom:24px; right:24px; z-index:999;
    background:linear-gradient(135deg,var(--green-bright),var(--green-deep));
    color:#fff; padding:12px 22px; border-radius:12px;
    font-family:'DM Sans',sans-serif; font-size:.875rem; font-weight:600;
    box-shadow:0 8px 24px rgba(45,106,79,.35);
    animation:riseUp .3s cubic-bezier(.22,1,.36,1);
  `;
  document.body.appendChild(toast);
  setTimeout(() => toast.remove(), 3000);
}

  initRows();
</script>