            </button>
            <div class="petugas-dropdown-list" id="e_petugasList">
              <% if (petugas.length === 0) { %>
              <div style="padding:14px; text-align:center; color:#aac8b4; font-size:.84rem">
                Belum ada petugas tersedia
              </div>
              <% } %>
              <% petugas.forEach(item => { %>
              <div class="petugas-option" onclick="togglePetugasOption('e','<%= item.id_user %>','<%= item.nama_lengkap %>')">
                <input type="checkbox" id="e_cb_<%= item.id_user %>"
