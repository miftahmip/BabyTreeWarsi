                    display:flex; align-items:center; justify-content:space-between">
          <span style="font-size:.78rem; color:var(--brown-mid); font-weight:500">Total semua tahap</span>
          <span id="hargaTotalPreview"
                style="font-size:.95rem; font-weight:700; color:var(--green-deep)">Rp 0</span>
