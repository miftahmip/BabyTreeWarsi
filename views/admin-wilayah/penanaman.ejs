<% layout('layouts/admin-wilayah') %>

<style>
  .badge-status {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .3px;
  }
  .badge-aktif   { background: #e8f5e9; color: #2d6a4f; }
  .badge-selesai { background: #f3f4f6; color: #6b7280; }

  .btn-icon {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: .78rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: background .15s, transform .15s;
  }
  .btn-icon:hover { transform: translateY(-1px); }

  /* Paginasi */
  .pagination {
    display: flex; align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-top: 1px solid rgba(116,198,157,.15);
    flex-wrap: wrap; gap: 10px;
  }
  .pagination-info { font-size: .78rem; color: var(--brown-mid); }
  .pagination-btns { display: flex; align-items: center; gap: 4px; }
  .pg-btn {
    min-width: 32px; height: 32px;
    border-radius: 8px;
    border: 1.5px solid rgba(116,198,157,.3);
    background: transparent;
    color: var(--green-deep);
    font-family: 'DM Sans', sans-serif;
    font-size: .8rem; font-weight: 500;
    cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0 8px; transition: all .15s;
  }
  .pg-btn:hover:not(:disabled) { background: rgba(216,243,220,.5); border-color: var(--green-bright); }
  .pg-btn.active { background: var(--green-bright); border-color: var(--green-bright); color: #fff; font-weight: 600; }
  .pg-btn:disabled { opacity: .35; cursor: not-allowed; }

  /* Modal */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.35);
    z-index: 100; display: none;
    align-items: center; justify-content: center;
    padding: 16px;
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    background: #fff; border-radius: 20px;
    padding: 32px; width: 100%; max-width: 520px;
    max-height: 90vh; overflow-y: auto;
    box-shadow: 0 20px 60px rgba(26,71,49,.18);
    animation: riseUp .3s cubic-bezier(.22,1,.36,1);
  }
  @keyframes riseUp {
    from { opacity:0; transform:translateY(16px) scale(.97) }
    to   { opacity:1; transform:translateY(0)    scale(1)   }
  }
  .modal-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem; font-weight: 700;
    color: var(--green-deep); margin-bottom: 20px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .modal-close {
    background: none; border: none; cursor: pointer;
    color: #aaa; font-size: 1.2rem; line-height: 1; transition: color .15s;
  }
  .modal-close:hover { color: var(--green-deep); }

  .mform-group { margin-bottom: 18px; }
  .mform-label {
    display: block; font-size: .7rem; font-weight: 600;
    letter-spacing: .8px; text-transform: uppercase;
    color: var(--green-deep); margin-bottom: 7px;
  }
  .mform-wrap { position: relative; }
  .mform-ico {
    position: absolute; left: 12px; top: 50%;
    transform: translateY(-50%);
    color: var(--green-bright); pointer-events: none;
    display: flex; align-items: center;
  }
  .mform-input {
    width: 100%; padding: 11px 12px 11px 38px;
    border-radius: 10px;
    border: 1.5px solid rgba(116,198,157,.42);
    background: rgba(216,243,220,.18);
    font-family: 'DM Sans', sans-serif;
    font-size: .88rem; color: var(--green-deep);
    outline: none; box-sizing: border-box; appearance: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
  }
  .mform-input::placeholder { color: #aac8b4; }
  .mform-input:focus {
    border-color: var(--green-bright);
    background: rgba(216,243,220,.38);
    box-shadow: 0 0 0 3px rgba(64,145,108,.11);
  }
  .mform-btn {
    width: 100%; padding: 12px; border: none; border-radius: 11px;
    background: linear-gradient(135deg, var(--green-bright), var(--green-deep));
    color: #fff; font-family: 'DM Sans', sans-serif;
    font-size: .95rem; font-weight: 600; cursor: pointer;
    box-shadow: 0 4px 16px rgba(45,106,79,.35);
    transition: transform .18s, box-shadow .18s; margin-top: 8px;
  }
  .mform-btn:hover  { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(45,106,79,.42); }
  .mform-btn:active { transform: translateY(0);    box-shadow: 0 3px 8px rgba(45,106,79,.3);  }

  /* Multi-select petugas */
  .petugas-dropdown {
    position: relative;
  }
  .petugas-trigger {
    width: 100%; padding: 11px 38px 11px 38px;
    border-radius: 10px;
    border: 1.5px solid rgba(116,198,157,.42);
    background: rgba(216,243,220,.18);
    font-family: 'DM Sans', sans-serif;
    font-size: .88rem; color: var(--green-deep);
    outline: none; box-sizing: border-box;
    cursor: pointer; text-align: left;
    transition: border-color .2s, box-shadow .2s;
    display: flex; align-items: center; justify-content: space-between;
  }
  .petugas-trigger:focus, .petugas-trigger.open {
    border-color: var(--green-bright);
    background: rgba(216,243,220,.38);
    box-shadow: 0 0 0 3px rgba(64,145,108,.11);
  }
  .petugas-trigger-text { color: #aac8b4; font-size: .88rem; flex: 1; }
  .petugas-trigger-text.has-value { color: var(--green-deep); }
  .petugas-dropdown-list {
    position: absolute; top: calc(100% + 4px); left: 0; right: 0;
    background: #fff;
    border: 1.5px solid rgba(116,198,157,.35);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(26,71,49,.12);
    z-index: 200; display: none;
    max-height: 200px; overflow-y: auto;
  }
  .petugas-dropdown-list.open { display: block; }
  .petugas-option {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    border-bottom: 1px solid rgba(116,198,157,.1);
    cursor: pointer; transition: background .15s;
  }
  .petugas-option:last-child { border-bottom: none; }
  .petugas-option:hover { background: rgba(216,243,220,.35); }
  .petugas-option input[type="checkbox"] {
    width: 15px; height: 15px;
    accent-color: var(--green-bright); flex-shrink: 0;
  }
  .petugas-option label { font-size: .88rem; color: var(--green-deep); cursor: pointer; margin: 0; }

  /* Tags selected petugas */
  .petugas-tags {
    display: flex; flex-wrap: wrap; gap: 5px; margin-top: 8px;
  }
  .petugas-tag {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px 3px 10px; border-radius: 14px;
    background: rgba(216,243,220,.6);
    border: 1px solid rgba(116,198,157,.3);
    font-size: .75rem; font-weight: 500; color: var(--green-deep);
  }
  .petugas-tag-remove {
    background: none; border: none; cursor: pointer;
    color: #aac8b4; font-size: .85rem; line-height: 1;
    padding: 0; display: flex; align-items: center;
    transition: color .15s;
  }
  .petugas-tag-remove:hover { color: #b03030; }

  /* Search */
  .search-wrap { position: relative; }
  .search-wrap input {
    padding: 10px 14px 10px 38px; border-radius: 10px;
    border: 1.5px solid rgba(116,198,157,.35);
    background: rgba(255,255,255,.8);
    font-family: 'DM Sans', sans-serif;
    font-size: .875rem; color: var(--green-deep);
    outline: none; width: 220px;
    transition: border-color .2s, box-shadow .2s;
  }
  .search-wrap input:focus {
    border-color: var(--green-bright);
    box-shadow: 0 0 0 3px rgba(64,145,108,.1);
  }
  .search-wrap .search-ico {
    position: absolute; left: 11px; top: 50%;
    transform: translateY(-50%);
    color: #aac8b4; pointer-events: none;
  }

  .validasi-msg {
    display: none; font-size: .75rem; color: #b03030;
    text-align: center; padding: 8px 12px;
    background: #fff0f0; border: 1px solid #f5c6c6;
    border-radius: 8px; margin-top: 10px;
  }

  .hapus-modal-box {
    background: #fff; border-radius: 20px;
    padding: 32px; width: 100%; max-width: 360px;
    text-align: center;
    box-shadow: 0 20px 60px rgba(26,71,49,.18);
    animation: riseUp .3s cubic-bezier(.22,1,.36,1);
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
</style>


<!-- Header -->
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:12px">
  <div>
    <h2 style="font-family:'Playfair Display',serif; font-size:1.4rem; font-weight:700;
               color:var(--green-deep); margin-bottom:3px">Data Penugasan Penanaman Pohon</h2>
    <p style="font-size:.84rem; color:var(--brown-mid); font-weight:300">
      Kelola penugasan penanaman pohon
    </p>
  </div>
  <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap">

    <div class="search-wrap">
      <span class="search-ico">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35" stroke-linecap="round"/>
        </svg>
      </span>
      <input type="text" id="searchInput" placeholder="Cari program atau petugas..." />
    </div>

    <button onclick="openModal('createModal')"
            style="display:inline-flex; align-items:center; gap:7px; padding:10px 18px;
                   border-radius:11px; border:none; cursor:pointer;
                   background:linear-gradient(135deg,var(--green-bright),var(--green-deep));
                   color:#fff; font-family:'DM Sans',sans-serif; font-size:.875rem; font-weight:600;
                   box-shadow:0 4px 14px rgba(45,106,79,.32); transition:transform .18s, box-shadow .18s"
            onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 7px 20px rgba(45,106,79,.42)'"
            onmouseout="this.style.transform='';this.style.boxShadow='0 4px 14px rgba(45,106,79,.32)'">
      <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Tambah Penanaman
    </button>
  </div>
</div>


<!-- Tabel -->
<div style="background:#fff; border:1px solid rgba(116,198,157,.2); border-radius:16px; overflow:hidden">
  <div style="overflow-x:auto">
    <table style="width:100%; border-collapse:collapse; font-size:.875rem; min-width:700px">
      <thead>
        <tr style="background:rgba(216,243,220,.3); border-bottom:1px solid rgba(116,198,157,.18)">
          <th style="padding:13px 18px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">No</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Program</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Tanggal</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Petugas Lapangan</th>
          <th style="padding:13px 16px; text-align:left; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Status</th>
          <th style="padding:13px 16px; text-align:center; font-size:.68rem; font-weight:600; letter-spacing:.9px; text-transform:uppercase; color:var(--brown-mid)">Aksi</th>
        </tr>
      </thead>
      <tbody id="tableBody">

        <% if (data.length === 0) { %>
        <tr>
          <td colspan="6" style="padding:52px; text-align:center; color:#aac8b4">
            <svg width="38" height="38" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                 stroke-width="1.2" style="display:block; margin:0 auto 10px">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <path d="M16 2v4M8 2v4M3 10h18"/>
            </svg>
            Belum ada data penanaman
          </td>
        </tr>
        <% } %>

        <% data.forEach((item, index) => { %>
        <tr class="data-row"
            style="border-bottom:1px solid rgba(116,198,157,.08); transition:background .15s"
            onmouseover="this.style.background='rgba(240,250,244,.6)'"
            onmouseout="this.style.background=''">

          <td class="nomor" style="padding:13px 18px; color:#999; font-size:.8rem"><%= index + 1 %></td>

          <td class="program-col" style="padding:13px 16px; font-weight:500; color:var(--green-deep)">
            <%= item.program?.judul_program || '-' %>
          </td>

          <td style="padding:13px 16px; font-size:.84rem; color:#444; white-space:nowrap">
            <div>
              <%= new Date(item.tanggal_mulai).toLocaleDateString('id-ID', {
                day: '2-digit', month: 'short', year: 'numeric'
              }) %>
            </div>
            <div style="color:#444; margin-top:2px">
              s.d. <%= new Date(item.tanggal_selesai).toLocaleDateString('id-ID', {
                day: '2-digit', month: 'short', year: 'numeric'
              }) %>
            </div>
          </td>

          <td class="petugas-col" style="padding:13px 16px">
            <% if (item.detailPenanaman && item.detailPenanaman.length > 0) { %>
            <div style="display:flex; flex-wrap:wrap; gap:5px">
              <% item.detailPenanaman.forEach(detail => { %>
              <span style="display:inline-block; padding:3px 9px; border-radius:14px;
                           background:rgba(216,243,220,.5); color:var(--green-deep);
                           font-size:.72rem; font-weight:500;
                           border:1px solid rgba(116,198,157,.25)">
                <%= detail.petugas?.nama_lengkap %>
              </span>
              <% }) %>
            </div>
            <% } else { %>
            <span style="color:#aac8b4; font-size:.84rem">—</span>
            <% } %>
          </td>

          <td style="padding:13px 16px">
            <span class="badge-status <%= item.status_penanaman === 'aktif' ? 'badge-aktif' : 'badge-selesai' %>">
              <%= item.status_penanaman === 'aktif' ? 'Aktif' : 'Selesai' %>
            </span>
          </td>

          <td style="padding:13px 16px; text-align:center">
            <div style="display:flex; align-items:center; justify-content:center; gap:7px">

              <!-- Harga -->
              <button class="btn-icon btnHarga"
                      style="background:rgba(255,243,205,.6); color:#92600a; border:1px solid rgba(255,220,100,.35)"
                      onmouseover="this.style.background='rgba(255,220,100,.4)'"
                      onmouseout="this.style.background='rgba(255,243,205,.6)'"
                      data-id="<%= item.id_penanaman %>"
                      data-program="<%= item.program?.judul_program || '-' %>">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="1" x2="12" y2="23"/>
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
                Harga
              </button>

              <!-- Edit -->
              <button class="btn-icon btnEdit"
                      style="background:rgba(216,243,220,.5); color:var(--green-deep); border:1px solid rgba(116,198,157,.3)"
                      onmouseover="this.style.background='rgba(116,198,157,.3)'"
                      onmouseout="this.style.background='rgba(216,243,220,.5)'"
                      data-id="<%= item.id_penanaman %>"
                      data-program="<%= item.id_program %>"
                      data-tanggal="<%= item.tanggal_mulai ? item.tanggal_mulai.toString().slice(0,10) : '' %>"
                      data-tanggal-selesai="<%= item.tanggal_selesai ? item.tanggal_selesai.toString().slice(0,10) : '' %>"
                      data-status="<%= item.status_penanaman %>"
                      data-petugas="<%= item.detailPenanaman.map(d => d.petugas?.id_user).filter(Boolean).join(',') %>">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Edit
              </button>

              <!-- Hapus -->
              <form action="/admin-wilayah/penanaman/delete/<%= item.id_penanaman %>" method="POST"
                    onsubmit="return confirmHapus(event, '<%= item.id_penanaman %>')">
                <button type="submit" class="btn-icon"
                        style="background:rgba(255,235,235,.6); color:#b03030; border:1px solid rgba(240,180,180,.35)"
                        onmouseover="this.style.background='rgba(240,180,180,.4)'"
                        onmouseout="this.style.background='rgba(255,235,235,.6)'">
                  <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                  </svg>
                  Hapus
                </button>
              </form>

            </div>
          </td>
        </tr>
        <% }) %>

        <tr id="noResultRow" style="display:none">
          <td colspan="6" style="padding:40px; text-align:center; color:#aac8b4; font-size:.875rem">
            Tidak ada data yang cocok
          </td>
        </tr>

      </tbody>
    </table>
  </div>

  <div class="pagination">
    <span class="pagination-info" id="paginasiInfo"></span>
    <div class="pagination-btns" id="paginasiBtns"></div>
  </div>
</div>


<!-- ════════ MODAL CREATE ════════ -->
<div id="createModal" class="modal-overlay">
  <div class="modal-box">
    <div class="modal-title">
      Tambah Penanaman
      <button class="modal-close" onclick="closeModal('createModal')">✕</button>
    </div>
    <form action="/admin-wilayah/penanaman/create" method="POST" id="createForm">

      <!-- Program -->
      <div class="mform-group">
        <label class="mform-label">Program Donasi</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M12 22V12" stroke-linecap="round"/>
              <path d="M12 12C12 12 8 9 8 5C8 2.5 10 1 12 1C14 1 16 2.5 16 5C16 9 12 12 12 12Z"/>
            </svg>
          </span>
          <select name="id_program" class="mform-input" required>
            <option value="" disabled selected>Pilih program donasi</option>
            <% program.forEach(item => { %>
            <option value="<%= item.id_program %>"><%= item.judul_program %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <!-- Tanggal -->
      <div class="mform-group">
        <label class="mform-label">Tanggal Mulai Penanaman</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <path d="M16 2v4M8 2v4M3 10h18"/>
            </svg>
          </span>
          <input type="date" name="tanggal_mulai" class="mform-input" required />
        </div>
      </div>

      <!-- Tanggal Selesai -->
      <div class="mform-group">
        <label class="mform-label">Tanggal Selesai Penanaman</label>
        <div class="mform-wrap">
          <span class="mform-ico">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <path d="M16 2v4M8 2v4M3 10h18"/>
              <path d="M9 16l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <input type="date" name="tanggal_selesai" class="mform-input" />
        </div>
      </div>

      <!-- Petugas multi-select -->
      <div class="mform-group">
        <label class="mform-label">Petugas Lapangan</label>
        <div class="mform-wrap">
          <span class="mform-ico" style="z-index:1">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="9" cy="7" r="3"/>
              <path d="M3 21v-2a5 5 0 0 1 5-5h2" stroke-linecap="round"/>
            </svg>
          </span>
          <div class="petugas-dropdown" id="c_petugasDropdown">
            <button type="button" class="petugas-trigger" id="c_petugasTrigger"
                    onclick="togglePetugasDropdown('c')">
              <span class="petugas-trigger-text" id="c_petugasText">Pilih petugas lapangan</span>
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="petugas-dropdown-list" id="c_petugasList">
              <% if (petugas.length === 0) { %>
              <div style="padding:14px; text-align:center; color:#aac8b4; font-size:.84rem">
                Belum ada petugas tersedia
              </div>
              <% } %>
              <% petugas.forEach(item => { %>
              <div class="petugas-option" onclick="togglePetugasOption('c','<%= item.id_user %>','<%= item.nama_lengkap %>')">
                <input type="checkbox" id="c_cb_<%= item.id_user %>"
                       value="<%= item.id_user %>" data-nama="<%= item.nama_lengkap %>"
                       onclick="event.stopPropagation()" />
                <label for="c_cb_<%= item.id_user %>"><%= item.nama_lengkap %></label>
              </div>
              <% }) %>
            </div>
          </div>
        </div>
        <!-- Tags -->
        <div class="petugas-tags" id="c_petugasTags"></div>
        <!-- Hidden inputs untuk submit -->
        <div id="c_petugasHidden"></div>
      </div>

      <p id="createValidasi" class="validasi-msg">Silahkan lengkapi data</p>
      <button type="submit" class="mform-btn">Simpan Data</button>
    </form>
  </div>
</div>


