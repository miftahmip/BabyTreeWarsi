<% layout('layouts/admin-wilayah') %>

<style>
  :root {
    --green-deep   : #1a4731;
    --green-bright : #40916c;
    --green-light  : #d8f3dc;
    --brown-mid    : #7c6d5e;
    --surface      : #ffffff;
    --border       : rgba(116,198,157,.18);
    --text-muted   : #7c9585;
  }

  .rp-back {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: .82rem; color: var(--text-muted);
    text-decoration: none; margin-bottom: 14px; transition: color .18s;
  }
  .rp-back:hover { color: var(--green-deep); }

  /* Header */
  .rp-header {
    display: flex; align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap; gap: 12px;
    margin-bottom: 24px;
  }

  .rp-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem; font-weight: 700;
    color: var(--green-deep); margin: 0 0 4px;
  }

  .rp-subtitle { font-size: .84rem; color: var(--text-muted); margin: 0; }

  /* Export button */
  .rp-btn-export {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 10px 18px; border-radius: 11px; border: none; cursor: pointer;
    background: linear-gradient(135deg, var(--green-bright), var(--green-deep));
    color: #fff; font-family: 'DM Sans', sans-serif;
    font-size: .86rem; font-weight: 600;
    box-shadow: 0 4px 14px rgba(45,106,79,.28);
    text-decoration: none;
    transition: transform .15s, box-shadow .15s;
  }
  .rp-btn-export:hover {
    transform: translateY(-1px);
    box-shadow: 0 7px 20px rgba(45,106,79,.38);
  }

  /* Stat cards */
  .rp-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 14px; margin-bottom: 24px;
  }

  .rp-stat {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px; padding: 16px 18px;
    display: flex; align-items: center; gap: 12px;
  }

  .rp-stat-icon {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }

  .rp-stat-val {
    font-size: 1.25rem; font-weight: 700; color: var(--green-deep); line-height: 1;
  }

  .rp-stat-lbl { font-size: .7rem; color: var(--text-muted); margin-top: 3px; }

  /* Table card */
  .rp-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px; overflow: hidden;
  }

  .rp-card-bar {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    font-size: .8rem; font-weight: 600;
    color: var(--green-deep); letter-spacing: .3px;
  }

  .rp-table {
    width: 100%; border-collapse: collapse;
    font-size: .875rem; min-width: 800px;
  }

  .rp-table thead tr {
    background: rgba(216,243,220,.25);
    border-bottom: 1px solid var(--border);
  }

  .rp-table th {
    padding: 11px 14px; text-align: center;
    font-size: .67rem; font-weight: 600;
    letter-spacing: .9px; text-transform: uppercase;
    color: var(--brown-mid); white-space: nowrap;
  }

  .rp-table th:first-child,
  .rp-table td:first-child { text-align: left; }

  .rp-table td {
    padding: 12px 14px; text-align: center;
    border-bottom: 1px solid rgba(116,198,157,.07);
    vertical-align: middle;
  }

  .rp-table tbody tr:last-child td { border-bottom: none; }
  .rp-table tbody tr:hover td { background: rgba(240,250,244,.5); }

  /* Total row */
  .rp-table tfoot tr td {
    padding: 12px 14px; text-align: center;
    font-weight: 700; color: var(--green-deep);
    background: rgba(216,243,220,.2);
    border-top: 2px solid rgba(116,198,157,.3);
    font-size: .88rem;
  }
  .rp-table tfoot tr td:first-child { text-align: left; }

  .rp-mitra-name { font-weight: 600; color: var(--green-deep); font-size: .86rem; }
  .rp-mitra-bank { font-size: .74rem; color: var(--text-muted); margin-top: 3px; }
  .rp-mitra-rekening { font-size: .74rem; color: var(--green-bright); font-weight: 600; margin-top: 1px; }

  .rp-num { font-size: .88rem; color: #555; }

  .rp-money {
    font-weight: 700; color: var(--green-deep);
    font-size: .88rem;
  }

  .rp-total-money {
    font-weight: 800; color: var(--green-deep);
    font-size: .88rem;
  }

  /* Footer */
  .rp-footer {
    padding: 12px 20px;
    border-top: 1px solid var(--border);
    font-size: .75rem; color: var(--text-muted);
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 8px;
  }

  /* Paginasi */
  .pagination-btns { display: flex; align-items: center; gap: 4px; }
  .pg-btn {
    min-width: 32px; height: 32px;
    border-radius: 8px;
    border: 1.5px solid rgba(116,198,157,.3);
    background: transparent;
    color: var(--green-deep);
    font-family: 'DM Sans', sans-serif;
    font-size: .8rem; font-weight: 500;
    cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0 8px; transition: all .15s;
  }
  .pg-btn:hover:not(:disabled) { background: rgba(216,243,220,.5); border-color: var(--green-bright); }
  .pg-btn.active { background: var(--green-bright); border-color: var(--green-bright); color: #fff; font-weight: 600; }
  .pg-btn:disabled { opacity: .35; cursor: not-allowed; }

  @media (max-width: 600px) {
    .rp-stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>


<%
  const totalMitra      = rekap.length;
  const totalPohonTanam = rekap.reduce((s,r) => s + r.total_tanam, 0);
  const totalHidup      = rekap.reduce((s,r) => s + r.monitoring_3, 0);
  const grandTotal      = rekap.reduce((s,r) => s + r.total_uang,   0);

  function rupiah(n) {
    return 'Rp ' + (n||0).toLocaleString('id-ID');
  }

  function rupiahSingkat(n) {
    n = n || 0;
    if (n >= 1000000000) return 'Rp ' + (n / 1000000000).toLocaleString('id-ID', { maximumFractionDigits: 1 }) + ' M';
    if (n >= 1000000)    return 'Rp ' + (n / 1000000).toLocaleString('id-ID',    { maximumFractionDigits: 1 }) + ' Jt';
    if (n >= 1000)       return 'Rp ' + (n / 1000).toLocaleString('id-ID',       { maximumFractionDigits: 1 }) + ' Rb';
    return 'Rp ' + n.toLocaleString('id-ID');
  }
%>


<a href="/admin-wilayah/rekap-pembayaran/program/<%= penanaman.id_program %>" class="rp-back">
  <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  Kembali ke Daftar Penanaman
</a>

<div class="rp-header">
  <div>
    <h1 class="rp-title">Rekap Pembayaran Mitra</h1>
  </div>
  <a href="/admin-wilayah/rekap-pembayaran/export/<%= penanaman.id_penanaman %>"
     class="rp-btn-export">
    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
      <polyline points="7 10 12 15 17 10"/>
      <line x1="12" y1="15" x2="12" y2="3"/>
    </svg>
    Export Excel
  </a>
</div>


<!-- Stat Cards -->
<div class="rp-stats">
  <div class="rp-stat">
    <div class="rp-stat-icon" style="background:rgba(216,243,220,.5)">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#40916c" stroke-width="1.8">
        <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke-linecap="round"/>
      </svg>
    </div>
    <div>
      <div class="rp-stat-val"><%= totalMitra %></div>
      <div class="rp-stat-lbl">Total Mitra</div>
    </div>
  </div>

  <div class="rp-stat">
    <div class="rp-stat-icon" style="background:rgba(186,230,253,.4)">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#0284c7" stroke-width="1.8">
        <path d="M12 22V12" stroke-linecap="round"/>
        <path d="M12 12C12 12 8 9 8 5C8 2.5 10 1 12 1C14 1 16 2.5 16 5C16 9 12 12 12 12Z"/>
      </svg>
    </div>
    <div>
      <div class="rp-stat-val"><%= totalPohonTanam %></div>
      <div class="rp-stat-lbl">Total Pohon Ditanam</div>
    </div>
  </div>

  <div class="rp-stat">
    <div class="rp-stat-icon" style="background:rgba(220,252,231,.5)">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#16a34a" stroke-width="1.8">
        <path d="M12 22V12" stroke-linecap="round"/>
        <path d="M12 12C12 12 8 9 8 5C8 2.5 10 1 12 1C14 1 16 2.5 16 5C16 9 12 12 12 12Z"/>
        <path d="M9 16l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div>
      <div class="rp-stat-val"><%= totalHidup %></div>
      <div class="rp-stat-lbl">Total Pohon Hidup</div>
    </div>
  </div>

  <div class="rp-stat">
    <div class="rp-stat-icon" style="background:rgba(187,247,208,.45)">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#16a34a" stroke-width="1.8">
        <rect x="2" y="5" width="20" height="14" rx="2"/>
        <path d="M2 10h20" stroke-linecap="round"/>
      </svg>
    </div>
    <div>
      <div class="rp-stat-val" style="font-size:1rem"><%= rupiah(grandTotal) %></div>
      <div class="rp-stat-lbl">Grand Total</div>
    </div>
  </div>
</div>


<!-- Tabel Rekap -->
<div class="rp-card">
  <div class="rp-card-bar">Rincian per Mitra</div>
  <div style="overflow-x:auto">
    <table class="rp-table">
      <thead>
        <tr>
          <th>Mitra</th>
          <th>Rekening</th>
          <th>Jml Tanam</th>
          <th>Monitoring 1</th>
          <th>Monitoring 2</th>
          <th>Monitoring 3</th>
          <th>Biaya Tanam</th>
          <th>Biaya M1</th>
          <th>Biaya M2</th>
          <th>Biaya M3</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody id="rekapTableBody">
        <% if (rekap.length === 0) { %>
          <tr id="emptyRow">
            <td colspan="11" style="padding:52px; text-align:center; color:#aac8b4">
              Belum ada data rekap
            </td>
          </tr>
        <% } %>
        <% rekap.forEach((item, idx) => {
          const biayaTanam = item.total_tanam  * (hargaMap.penanaman    || 0);
          const biayaM1    = item.monitoring_1 * (hargaMap.monitoring_1 || 0);
          const biayaM2    = item.monitoring_2 * (hargaMap.monitoring_2 || 0);
          const biayaM3    = item.monitoring_3 * (hargaMap.monitoring_3 || 0);
        %>
          <tr class="rekap-row" data-index="<%= idx %>">
            <td>
              <div class="rp-mitra-name"><%= item.mitra %></div>
            </td>
            <td>
              <% if (item.bank) { %>
              <div style="font-size:.78rem; font-weight:600; color:var(--green-deep)"><%= item.bank %></div>
              <% } %>
              <% if (item.no_rekening) { %>
              <div style="font-size:.78rem; color:#555; margin-top:2px"><%= item.no_rekening %></div>
              <% } %>
              <% if (item.atas_nama_bank) { %>
              <div style="font-size:.74rem; color:var(--text-muted); margin-top:1px">a.n <%= item.atas_nama_bank %></div>
              <% } %>
              <% if (!item.bank && !item.no_rekening && !item.atas_nama_bank) { %>
              <span style="color:#aac8b4; font-size:.84rem">—</span>
              <% } %>
            </td>
            <td><span class="rp-num"><%= item.total_tanam %></span></td>
            <td><span class="rp-num"><%= item.monitoring_1 %></span></td>
            <td><span class="rp-num"><%= item.monitoring_2 %></span></td>
            <td><span class="rp-num"><%= item.monitoring_3 %></span></td>
            <td><span class="rp-money"><%= rupiahSingkat(biayaTanam) %></span></td>
            <td><span class="rp-money"><%= rupiahSingkat(biayaM1) %></span></td>
            <td><span class="rp-money"><%= rupiahSingkat(biayaM2) %></span></td>
            <td><span class="rp-money"><%= rupiahSingkat(biayaM3) %></span></td>
            <td><span class="rp-total-money"><%= rupiah(item.total_uang) %></span></td>
          </tr>
        <% }) %>
      </tbody>
      <% if (rekap.length > 0) { %>
      <tfoot id="rekapTfoot">
        <tr>
          <td><strong>Total Keseluruhan</strong></td>
          <td></td>
          <td><%= rekap.reduce((s,r)=>s+r.total_tanam,0) %></td>
          <td><%= rekap.reduce((s,r)=>s+r.monitoring_1,0) %></td>
          <td><%= rekap.reduce((s,r)=>s+r.monitoring_2,0) %></td>
          <td><%= rekap.reduce((s,r)=>s+r.monitoring_3,0) %></td>
          <td><%= rupiahSingkat(rekap.reduce((s,r)=>s+(r.total_tanam*(hargaMap.penanaman||0)),0)) %></td>
          <td><%= rupiahSingkat(rekap.reduce((s,r)=>s+(r.monitoring_1*(hargaMap.monitoring_1||0)),0)) %></td>
          <td><%= rupiahSingkat(rekap.reduce((s,r)=>s+(r.monitoring_2*(hargaMap.monitoring_2||0)),0)) %></td>
          <td><%= rupiahSingkat(rekap.reduce((s,r)=>s+(r.monitoring_3*(hargaMap.monitoring_3||0)),0)) %></td>
          <td><%= rupiah(grandTotal) %></td>
        </tr>
      </tfoot>
      <% } %>
    </table>
  </div>

  <div class="rp-footer">
    <span id="paginasiInfo"></span>
    <div class="pagination-btns" id="paginasiBtns"></div>
  </div>
</div>


<script>
  const PER_PAGE  = 7;
  let allRows     = [];
  let currentPage = 1;

  function initPaginasi() {
    allRows = Array.from(document.querySelectorAll('.rekap-row'));
    if (allRows.length === 0) return;
    renderPage(1);
  }

  function renderPage(page) {
    currentPage       = page;
    const total       = allRows.length;
    const totalPages  = Math.max(1, Math.ceil(total / PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;

    const start = (currentPage - 1) * PER_PAGE;
    const end   = start + PER_PAGE;

    allRows.forEach((r, i) => {
      r.style.display = (i >= start && i < end) ? '' : 'none';
    });

    // Sembunyikan tfoot jika bukan halaman terakhir yang menampilkan semua
    // tfoot tetap tampil selalu sebagai ringkasan keseluruhan
    renderPaginasiUI(currentPage, totalPages, total, start, Math.min(end, total));
  }

  function renderPaginasiUI(page, totalPages, total, start, end) {
    document.getElementById('paginasiInfo').textContent =
      `Menampilkan ${start + 1}–${end} dari ${total} mitra`;

    const container = document.getElementById('paginasiBtns');
    container.innerHTML = '';

    // Prev
    const prev = document.createElement('button');
    prev.className = 'pg-btn';
    prev.innerHTML = `<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    prev.disabled  = page <= 1;
    prev.onclick   = () => renderPage(page - 1);
    container.appendChild(prev);

    // Nomor halaman
    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || (i >= page - 1 && i <= page + 1)) {
        const btn = document.createElement('button');
        btn.className   = 'pg-btn' + (i === page ? ' active' : '');
        btn.textContent = i;
        btn.onclick     = () => renderPage(i);
        container.appendChild(btn);
      } else if (i === page - 2 || i === page + 2) {
        const dots = document.createElement('span');
        dots.textContent = '…';
        dots.style.cssText = 'color:#aac8b4; font-size:.8rem; padding:0 4px; align-self:center';
        container.appendChild(dots);
      }
    }

    // Next
    const next = document.createElement('button');
    next.className = 'pg-btn';
    next.innerHTML = `<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    next.disabled  = page >= totalPages;
    next.onclick   = () => renderPage(page + 1);
    container.appendChild(next);
  }

  initPaginasi();
</script>
