<% layout('layouts/petugas') %>

<style>

    /* RESPONSIVE */

    /* Tablet (max 1024px) */
    @media (max-width: 1024px) {
    .penanaman-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }
    }

    /* Handphone (max 640px) */
    @media (max-width: 640px) {
    .penanaman-grid {
        grid-template-columns: 1fr;
        gap: 12px;
    }

    .page-header h3 {
        font-size: 1.15rem;
    }

    .card-body-inner {
        padding: 14px 14px 14px;
    }

    .info-grid {
        grid-template-columns: 1fr 1fr; /* tetap 2 kolom di HP */
    }

    .btn-kelola {
        padding: 10px 24px;
        font-size: .82rem;
    }
    }
    
  .page-header {
    margin-bottom: 22px;
  }
  .page-header h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--green-deep);
    margin-bottom: 4px;
  }
  .page-header p {
    font-size: .875rem;
    color: #7a8c85;
    margin: 0;
  }

  /* GRID */
  .penanaman-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  /* CARD */
  .penanaman-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(116,198,157,0.18);
    box-shadow: 0 2px 12px rgba(26,71,49,0.07);
    display: flex;
    flex-direction: column;
    transition: transform .22s ease, box-shadow .22s ease;
    animation: cardIn .4s ease both;
  }
  .penanaman-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 32px rgba(26,71,49,0.13);
  }

  @keyframes cardIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* stagger tiap card */
  .penanaman-card:nth-child(1) { animation-delay: .05s; }
  .penanaman-card:nth-child(2) { animation-delay: .10s; }
  .penanaman-card:nth-child(3) { animation-delay: .15s; }
  .penanaman-card:nth-child(4) { animation-delay: .20s; }
  .penanaman-card:nth-child(5) { animation-delay: .25s; }
  .penanaman-card:nth-child(6) { animation-delay: .30s; }

  /* CARD TOP ACCENT */
  .card-accent {
    height: 5px;
    background: linear-gradient(90deg, var(--green-bright), var(--green-light));
  }

  /* CARD BODY */
  .card-body-inner {
    padding: 16px 18px 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 12px;
  }

  /* JUDUL + BADGE STATUS */
  .card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
  }
  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: .92rem;
    font-weight: 600;
    color: var(--green-deep);
    line-height: 1.35;
    flex: 1;
  }
  .status-badge {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 8px;
    border-radius: 20px;
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .3px;
    text-transform: uppercase;
  }
  .status-badge.aktif {
    background: #e6f7ef;
    color: #1a7a47;
  }
  .status-badge.selesai {
    background: #f0f0f0;
    color: #666;
  }
  .status-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: currentColor;
  }
  .status-badge.aktif .status-dot {
    background: #2ecc71;
    box-shadow: 0 0 0 2px rgba(46,204,113,0.3);
    animation: pulse-dot 1.8s infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 2px rgba(46,204,113,0.3); }
    50%       { box-shadow: 0 0 0 5px rgba(46,204,113,0.1); }
  }

  /* DIVIDER */
  .card-divider {
    height: 1px;
    background: rgba(116,198,157,0.15);
  }

  /* INFO ROWS */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 14px;
  }
  .info-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .info-label {
    font-size: .63rem;
    color: #a0b0a8;
    text-transform: uppercase;
    letter-spacing: .5px;
    font-weight: 500;
  }
  .info-value {
    font-size: .78rem;
    color: var(--green-deep);
    font-weight: 500;
    line-height: 1.3;
  }

  /* POHON ROW */
  .pohon-row {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--green-ghost);
    border-radius: 10px;
    padding: 8px 12px;
  }
  .pohon-info .pohon-count {
    font-size: .95rem;
    font-weight: 700;
    color: var(--green-deep);
    line-height: 1;
  }
  .pohon-info .pohon-label {
    font-size: .65rem;
    color: #7a8c85;
    margin-top: 1px;
  }

  /* CTA BUTTON */
  .btn-kelola {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    align-self: center;
    padding: 9px 24px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--green-bright) 0%, var(--green-deep) 100%);
    color: #fff;
    text-decoration: none;
    font-size: .8rem;
    font-weight: 600;
    letter-spacing: .2px;
    border: none;
    cursor: pointer;
    transition: background .2s, transform .15s, box-shadow .2s;
    margin-top: auto;
  }
  .btn-kelola:hover {
    background: linear-gradient(135deg, var(--green-light) 0%, var(--green-mid) 100%);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(26,71,49,0.28);
  }
  .btn-kelola svg { flex-shrink: 0; }

  /* EMPTY STATE */
  .empty-state {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 72px 24px;
    background: #fff;
    border-radius: 16px;
    border: 1.5px dashed rgba(116,198,157,0.4);
    text-align: center;
    animation: cardIn .4s ease both;
  }
  .empty-icon {
    width: 72px; height: 72px;
    border-radius: 18px;
    background: var(--green-ghost);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 18px;
  }
  .empty-icon svg { color: var(--green-bright); }
  .empty-state h5 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--green-deep);
    margin-bottom: 6px;
  }
  .empty-state p {
    font-size: .85rem;
    color: #7a8c85;
    margin: 0;
    max-width: 280px;
  }
</style>

<!-- HEADER -->
<div class="page-header">
  <h3>Penugasan Penanaman Saya</h3>
  <p>Daftar program yang ditugaskan kepada Anda</p>
</div>

<!-- GRID PENANAMAN -->
<div class="penanaman-grid">

  <% if (data.length > 0) { %>

    <% data.forEach((item, i) => { %>

      <div class="penanaman-card">

        <!-- Accent bar -->
        <div class="card-accent"></div>

        <div class="card-body-inner">

          <!-- Judul + Status -->
          <div class="card-head">
            <div class="card-title">
              <%= item.penanaman.program.judul_program %>
            </div>
            <% if (item.penanaman.status_penanaman === 'aktif') { %>
              <span class="status-badge aktif">
                <span class="status-dot"></span>
                Aktif
              </span>
            <% } else { %>
              <span class="status-badge selesai">
                <span class="status-dot"></span>
                Selesai
              </span>
            <% } %>
          </div>

          <div class="card-divider"></div>

          <!-- Info Lokasi -->
          <div class="info-grid">
            <div class="info-item">
              <span class="info-label">Kelurahan</span>
              <span class="info-value"><%= item.penanaman.program.nama_kelurahan || '—' %></span>
            </div>
            <div class="info-item">
              <span class="info-label">Kecamatan</span>
              <span class="info-value"><%= item.penanaman.program.nama_kecamatan || '—' %></span>
            </div>
            <div class="info-item">
              <span class="info-label">Kab / Kota</span>
              <span class="info-value"><%= item.penanaman.program.nama_kota || '—' %></span>
            </div>
            <div class="info-item">
              <span class="info-label">Provinsi</span>
              <span class="info-value"><%= item.penanaman.program.nama_provinsi || '—' %></span>
            </div>
          </div>

          <div class="card-divider"></div>

          <!-- Jumlah Pohon -->
          <div class="pohon-row">
            <div class="pohon-info">
              <div class="pohon-count"><%= item.penanaman.program.pohon_terkumpul %> Pohon</div>
            </div>
          </div>

          <!-- CTA -->
          <a href="/petugas-lapangan/pohon/<%= item.penanaman.id_penanaman %>" class="btn-kelola">
            Kelola Data Pohon
          </a>

        </div>
      </div>

    <% }) %>

  <% } else { %>

    <!-- EMPTY STATE -->
    <div class="empty-state">
      <div class="empty-icon">
        <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <polygon points="12,2 7,9 17,9" stroke-linejoin="round"></polygon>
          <polygon points="12,6 5.5,14 18.5,14" stroke-linejoin="round"></polygon>
          <polygon points="12,10 4,20 20,20" stroke-linejoin="round"></polygon>
          <line x1="12" y1="20" x2="12" y2="22" stroke-linecap="round"></line>
        </svg>
      </div>
      <h5>Belum Ada Penugasan Penanaman</h5>
      <p>Saat ini Anda belum memiliki penugasan program. Hubungi Admin Wilayah untuk informasi lebih lanjut.</p>
    </div>

  <% } %>

</div>