<% layout('layouts/petugas') %>

<style>
  :root {
    --green-deep:   #1a4731;
    --green-mid:    #2d6a4f;
    --green-bright: #40916c;
    --green-light:  #74c69d;
    --green-pale:   #d8f3dc;
    --green-ghost:  #f0faf4;
    --brown-mid:    #7d5a3c;
    --cream:        #fdf8f0;
  }

  .dp-page {
    padding: 28px 32px;
    background: var(--cream);
    min-height: 100vh;
    font-family: 'DM Sans', sans-serif;
    max-width: 960px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .dp-btn-back {
    display: inline-flex; align-items: center; gap: 6px;
    background: none; border: none; cursor: pointer;
    font-family: inherit; font-size: 13px; font-weight: 600;
    color: var(--brown-mid); padding: 0; margin-bottom: 20px;
    text-decoration: none; transition: color .15s;
  }
  .dp-btn-back:hover { color: var(--green-deep); }

  .dp-card {
    background: white; border: 1px solid #dceee3;
    border-radius: 14px; overflow: hidden; margin-bottom: 16px;
  }

  .dp-card-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px; border-bottom: 1px solid var(--green-ghost);
    flex-wrap: wrap; gap: 8px;
  }

  .dp-card-title { font-size: 15px; font-weight: 700; color: var(--green-deep); line-height: 1.2; }
  .dp-card-sub   { font-size: 12px; color: #9abfad; margin-top: 2px; }
  .dp-card-head-right { display: flex; align-items: center; gap: 8px; }

  .dp-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 600;
  }
  .dp-badge-menunggu  { background: #fff8e1; color: #f57f17; border: 1px solid #ffe082; }
  .dp-badge-disetujui { background: var(--green-ghost); color: var(--green-mid); border: 1px solid var(--green-pale); }
  .dp-badge-revisi    { background: #ffebee; color: #b03030; border: 1px solid #ffcdd2; }

  .dp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0; padding: 4px 0;
  }
  .dp-field { padding: 12px 20px; }
  .dp-field-label { font-size: 11px; color: #9abfad; font-weight: 500; margin-bottom: 3px; }
  .dp-field-value { font-size: 14px; font-weight: 600; color: var(--green-deep); }

  .dp-foto-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 10px; padding: 16px 20px;
    border-top: 1px solid var(--green-ghost);
  }
  .dp-foto-grid img {
    width: 100%; aspect-ratio: 1; object-fit: cover;
    border-radius: 10px; border: 1px solid var(--green-pale);
  }

  .dp-koreksi {
    margin: 0 20px 16px; padding: 12px 16px;
    background: #ffebee; border: 1px solid #ffcdd2; border-radius: 10px;
  }
  .dp-koreksi-label {
    font-size: 11px; font-weight: 600; color: #b03030;
    margin-bottom: 4px; letter-spacing: .4px; text-transform: uppercase;
  }
  .dp-koreksi-text { font-size: 13px; color: #b03030; }

  .dp-edit-form {
    display: none; padding: 16px 20px;
    border-top: 1px solid var(--green-ghost);
  }
  .dp-edit-form.active { display: block; }

  .dp-form-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 12px; margin-bottom: 12px;
  }
  .dp-form-group { display: flex; flex-direction: column; gap: 5px; }
  .dp-form-group.full  { grid-column: 1 / -1; }
  .dp-form-group.span2 { grid-column: span 2; }

  .dp-form-label { font-size: 11px; color: #9abfad; font-weight: 500; }

  .dp-form-input,
  .dp-form-select,
  .dp-form-textarea {
    font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600;
    color: var(--green-deep); background: var(--green-ghost);
    border: 1px solid var(--green-pale); border-radius: 8px;
    padding: 8px 12px; outline: none; transition: border-color .15s;
    width: 100%; box-sizing: border-box; appearance: none;
  }
  .dp-form-input:focus,
  .dp-form-select:focus,
  .dp-form-textarea:focus { border-color: var(--green-bright); }
  .dp-form-textarea { resize: vertical; min-height: 70px; }

  .dp-form-input-static {
    font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600;
    color: #9abfad; background: var(--green-ghost); border: 1px solid var(--green-pale);
    border-radius: 8px; padding: 8px 12px; width: 100%;
    box-sizing: border-box; cursor: not-allowed;
  }

  .dp-foto-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 14px; border-radius: 8px; cursor: pointer;
    font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 600;
    border: 1.5px dashed rgba(116,198,157,.5);
    background: var(--green-ghost); color: var(--green-mid);
    transition: border-color .15s, background .15s;
  }
  .dp-foto-btn:hover { border-color: var(--green-bright); background: var(--green-pale); }

  .dp-foto-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
    gap: 8px; margin-top: 8px;
  }
  .dp-foto-preview-item {
    position: relative; border-radius: 8px; overflow: hidden;
    aspect-ratio: 1; border: 1.5px solid var(--green-pale);
  }
  .dp-foto-preview-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .dp-foto-remove {
    position: absolute; top: 3px; right: 3px;
    width: 18px; height: 18px; border-radius: 50%;
    background: rgba(176,48,48,.85); color: #fff;
    border: none; cursor: pointer; font-size: .6rem;
    display: flex; align-items: center; justify-content: center;
  }
  .dp-foto-count { font-size: .72rem; color: var(--green-bright); font-weight: 600; margin-top: 6px; }

  .dp-gps-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .dp-btn-gps {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 14px; border-radius: 20px;
    background: var(--green-ghost); color: var(--green-mid);
    font-family: inherit; font-size: 12px; font-weight: 600;
    border: 1px solid var(--green-pale); cursor: pointer;
    transition: background .15s; white-space: nowrap;
  }
  .dp-btn-gps:hover    { background: var(--green-pale); }
  .dp-btn-gps:disabled { opacity: .5; cursor: not-allowed; }
  .dp-gps-status { font-size: 11px; color: #9abfad; }

  .dp-form-actions {
    display: flex; justify-content: flex-end; gap: 8px;
    margin-top: 16px; padding-top: 12px;
    border-top: 1px solid var(--green-ghost);
  }
  .dp-btn-cancel {
    display: inline-flex; align-items: center;
    padding: 7px 18px; border-radius: 20px; background: white;
    color: #9abfad; font-family: inherit; font-size: 12px; font-weight: 600;
    border: 1px solid var(--green-pale); cursor: pointer; transition: color .15s;
  }
  .dp-btn-cancel:hover { color: var(--green-deep); }
  .dp-btn-save {
    display: inline-flex; align-items: center;
    padding: 7px 18px; border-radius: 20px;
    background: var(--green-mid); color: white;
    font-family: inherit; font-size: 12px; font-weight: 600;
    border: none; cursor: pointer; transition: background .15s;
  }
  .dp-btn-save:hover { background: var(--green-deep); }

  .dp-btn-edit,
  .dp-btn-update {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 14px; border-radius: 20px;
    background: var(--green-mid); color: white;
    font-family: inherit; font-size: 12px; font-weight: 600;
    border: none; cursor: pointer; transition: background .15s;
  }
  .dp-btn-edit:hover,
  .dp-btn-update:hover { background: var(--green-deep); }

  .dp-btn-belum {
    display: inline-flex; align-items: center;
    padding: 5px 14px; border-radius: 20px;
    background: var(--green-ghost); color: #9abfad;
    font-family: inherit; font-size: 12px; font-weight: 500;
    border: 1px solid var(--green-pale); cursor: default;
  }

  @media (max-width: 640px) {
    .dp-page      { padding: 16px 14px 32px; }
    .dp-grid      { grid-template-columns: 1fr 1fr; }
    .dp-form-grid { grid-template-columns: 1fr 1fr; }
    .dp-form-group.span2 { grid-column: 1 / -1; }
  }
  @media (max-width: 400px) {
    .dp-grid      { grid-template-columns: 1fr; }
    .dp-form-grid { grid-template-columns: 1fr; }
  }
</style>


<div class="dp-page">

  <a href="/petugas-lapangan/pohon/<%= data.penanaman?.id_penanaman || data.id_penanaman %>"
     class="dp-btn-back">← Kembali</a>


  <!-- ══ DATA PENANAMAN ══ -->
  <div class="dp-card">
    <div class="dp-card-head">
      <div>
        <div class="dp-card-title">Data Penanaman</div>
        <div class="dp-card-sub"><%= data.id_pohon %></div>
      </div>
      <div class="dp-card-head-right">
        <%
          const sv = data.status_verifikasi;
          const bc = sv==='disetujui'?'dp-badge-disetujui':sv==='menunggu'?'dp-badge-menunggu':'dp-badge-revisi';
          const bl = sv==='disetujui'?'Disetujui':sv==='menunggu'?'Menunggu':'Revisi';
        %>
        <span class="dp-badge <%= bc %>"><%= bl %></span>
        <button class="dp-btn-edit" id="btn-edit-penanaman"
                onclick="toggleSection('penanaman')">Edit</button>
      </div>
    </div>

    <!-- VIEW -->
    <div id="view-penanaman">
      <div class="dp-grid">
        <div class="dp-field">
          <div class="dp-field-label">Jenis Pohon</div>
          <div class="dp-field-value"><%= data.jenisPohon?.nama_pohon||'—' %></div>
        </div>
        <div class="dp-field">
          <div class="dp-field-label">Nama Latin</div>
          <div class="dp-field-value" style="font-style:italic"><%= data.jenisPohon?.nama_latin||'—' %></div>
        </div>
        <div class="dp-field">
          <div class="dp-field-label">Mitra</div>
          <div class="dp-field-value"><%= data.mitra?.nama_mitra||'—' %></div>
        </div>
        <div class="dp-field">
          <div class="dp-field-label">Tanggal Tanam</div>
          <div class="dp-field-value">
            <%= data.tgl_tanam?new Date(data.tgl_tanam).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}):'—' %>
          </div>
        </div>
        <div class="dp-field">
          <div class="dp-field-label">Latitude</div>
          <div class="dp-field-value"><%= data.latitude?parseFloat(data.latitude).toFixed(6):'—' %></div>
        </div>
        <div class="dp-field">
          <div class="dp-field-label">Longitude</div>
          <div class="dp-field-value"><%= data.longitude?parseFloat(data.longitude).toFixed(6):'—' %></div>
        </div>
      </div>

      <% if (data.status_verifikasi==='revisi'&&data.catatan_koreksi) { %>
        <div class="dp-koreksi">
          <div class="dp-koreksi-label">Catatan Koreksi</div>
          <div class="dp-koreksi-text"><%= data.catatan_koreksi %></div>
        </div>
      <% } %>

      <% const fotos=JSON.parse(data.foto_bukti_tanam||'[]'); %>
      <% if(fotos.length>0){ %>
        <div class="dp-foto-grid">
          <% fotos.forEach(f=>{ %><img src="/uploads/pohon/<%= f %>" alt="foto"><% }) %>
        </div>
      <% } %>
    </div>

    <!-- EDIT FORM -->
    <form id="form-penanaman" class="dp-edit-form"
          action="/petugas-lapangan/pohon/update/<%= data.id_pohon %>"
          method="POST" enctype="multipart/form-data">
      <input type="hidden" name="id_jenis_pohon" value="<%= data.id_jenis_pohon %>">
      <input type="hidden" name="latitude"  id="lat-penanaman"
             value="<%= data.latitude?parseFloat(data.latitude).toFixed(6):'' %>">
      <input type="hidden" name="longitude" id="lng-penanaman"
             value="<%= data.longitude?parseFloat(data.longitude).toFixed(6):'' %>">

      <div class="dp-form-grid">
        <div class="dp-form-group">
          <label class="dp-form-label">Jenis Pohon</label>
          <div class="dp-form-input-static"><%= data.jenisPohon?.nama_pohon||'—' %></div>
        </div>
        <div class="dp-form-group">
          <label class="dp-form-label">Mitra</label>
          <select name="id_mitra" class="dp-form-select">
            <% mitra.forEach(m=>{ %>
              <option value="<%= m.id_mitra %>" <%= m.id_mitra==data.id_mitra?'selected':'' %>><%= m.nama_mitra %></option>
            <% }) %>
          </select>
        </div>
        <div class="dp-form-group">
          <label class="dp-form-label">Tanggal Tanam</label>
          <input type="date" name="tgl_tanam" class="dp-form-input"
                 value="<%= data.tgl_tanam?new Date(data.tgl_tanam).toISOString().split('T')[0]:'' %>">
        </div>
        <div class="dp-form-group">
          <label class="dp-form-label">Latitude</label>
          <input type="text" id="show-lat-penanaman" class="dp-form-input" readonly
                 style="cursor:not-allowed;color:#9abfad;"
                 value="<%= data.latitude?parseFloat(data.latitude).toFixed(6):'' %>">
        </div>
        <div class="dp-form-group">
          <label class="dp-form-label">Longitude</label>
          <input type="text" id="show-lng-penanaman" class="dp-form-input" readonly
                 style="cursor:not-allowed;color:#9abfad;"
                 value="<%= data.longitude?parseFloat(data.longitude).toFixed(6):'' %>">
        </div>
        <div class="dp-form-group">
          <label class="dp-form-label">Lokasi GPS</label>
          <div class="dp-gps-row">
            <button type="button" class="dp-btn-gps"
                    onclick="ambilLokasi(event,'penanaman')">Perbarui Lokasi</button>
            <span class="dp-gps-status" id="gps-status-penanaman"></span>
          </div>
        </div>
        <div class="dp-form-group full">
          <label class="dp-form-label">Foto Bukti Tanam <span style="font-weight:300">(opsional)</span></label>
          <input type="file" id="input-foto-penanaman" name="foto_bukti_tanam"
                 multiple accept="image/*" style="display:none"
                 onchange="handleFoto('penanaman',this)">
          <button type="button" class="dp-foto-btn"
                  onclick="document.getElementById('input-foto-penanaman').click()">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="3"/>
              <circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
            </svg>
            Pilih dari File
          </button>
          <div class="dp-foto-preview-grid" id="preview-penanaman"></div>
          <div class="dp-foto-count"         id="count-penanaman"></div>
        </div>
      </div>

      <div class="dp-form-actions">
        <button type="button" class="dp-btn-cancel" onclick="toggleSection('penanaman')">Batal</button>
        <button type="submit" class="dp-btn-save">Simpan Perubahan</button>
      </div>
    </form>
  </div>


  <!-- ══ MONITORING ══ -->
  <%
    const monitoringList = [1,2,3];
    const monData = data.detailMonitoring || [];
  %>

  <% monitoringList.forEach((tahap, idx) => {
    const mon = monData.find(m => Number(m.monitoring?.tahap_monitoring) === tahap) || null;
    const prevDone = tahap===1 || monData.find(m => Number(m.monitoring?.tahap_monitoring) === tahap-1);
    const mf = mon ? JSON.parse(mon.foto_monitoring||'[]') : [];
    const msv = mon ? mon.status_verifikasi : null;
    const mbc = msv==='disetujui'?'dp-badge-disetujui':msv==='menunggu'?'dp-badge-menunggu':'dp-badge-revisi';
    const mbl = msv==='disetujui'?'Disetujui':msv==='menunggu'?'Menunggu':'Revisi';
  %>

  <div class="dp-card">
    <div class="dp-card-head">
      <div>
        <div class="dp-card-title">Monitoring ke-<%= tahap %></div>
        <% if(mon){ %>
          <div class="dp-card-sub">
            <%= mon.monitoring?.tgl_monitoring
              ? new Date(mon.monitoring.tgl_monitoring).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'})
              : '—' %>
          </div>
        <% } %>
      </div>
      <div class="dp-card-head-right">
        <% if(mon){ %>
          <span class="dp-badge <%= mbc %>"><%= mbl %></span>
          <button class="dp-btn-update" id="btn-edit-mon-<%= tahap %>"
                  onclick="toggleSection('mon-<%= tahap %>')">Edit</button>
        <% } else if(prevDone){ %>
          <button class="dp-btn-update" id="btn-create-mon-<%= tahap %>"
                  onclick="toggleSection('create-<%= tahap %>')">Update Kondisi</button>
        <% } else { %>
          <span class="dp-btn-belum">Belum tersedia</span>
        <% } %>
      </div>
    </div>

    <!-- VIEW (ada data) -->
    <% if(mon){ %>
      <div id="view-mon-<%= tahap %>">
        <div class="dp-grid">
          <div class="dp-field">
            <div class="dp-field-label">Tinggi Pohon</div>
            <div class="dp-field-value"><%= mon.tinggi_pohon %> cm</div>
          </div>
          <div class="dp-field">
            <div class="dp-field-label">Diameter Batang</div>
            <div class="dp-field-value"><%= mon.diameter_pohon %> cm</div>
          </div>
          <div class="dp-field">
            <div class="dp-field-label">Kesehatan Batang</div>
            <div class="dp-field-value"><%= mon.kesehatan_batang %></div>
          </div>
          <div class="dp-field">
            <div class="dp-field-label">Status Pohon</div>
            <div class="dp-field-value"><%= mon.status %></div>
          </div>
          <% if(mon.deskripsi){ %>
          <div class="dp-field" style="grid-column:span 2">
            <div class="dp-field-label">Deskripsi</div>
            <div class="dp-field-value" style="font-weight:500"><%= mon.deskripsi %></div>
          </div>
          <% } %>
        </div>

        <% if(mon.status_verifikasi==='revisi'&&mon.catatan_koreksi){ %>
          <div class="dp-koreksi">
            <div class="dp-koreksi-label">Catatan Koreksi</div>
            <div class="dp-koreksi-text"><%= mon.catatan_koreksi %></div>
          </div>
        <% } %>

        <% if(mf.length>0){ %>
          <div class="dp-foto-grid">
            <% mf.forEach(f=>{ %><img src="/uploads/monitoring/<%= f %>" alt="foto"><% }) %>
          </div>
        <% } %>
      </div>

      <!-- EDIT FORM monitoring -->
      <form id="form-mon-<%= tahap %>" class="dp-edit-form"
            action="/petugas-lapangan/monitoring/update/<%= mon.id_monitoring %>/<%= data.id_pohon %>"
            method="POST" enctype="multipart/form-data">
        <div class="dp-form-grid">
          <div class="dp-form-group">
            <label class="dp-form-label">Tinggi Pohon (cm)</label>
            <input type="number" step="0.01" name="tinggi_pohon" class="dp-form-input"
                   value="<%= mon.tinggi_pohon %>" required>
          </div>
          <div class="dp-form-group">
            <label class="dp-form-label">Diameter Batang (cm)</label>
            <input type="number" step="0.01" name="diameter_pohon" class="dp-form-input"
                   value="<%= mon.diameter_pohon %>" required>
          </div>
          <div class="dp-form-group">
            <label class="dp-form-label">Kesehatan Batang</label>
            <select name="kesehatan_batang" class="dp-form-select">
              <option value="baik"   <%= mon.kesehatan_batang==='baik'  ?'selected':'' %>>Sehat</option>
              <option value="buruk"  <%= mon.kesehatan_batang==='buruk' ?'selected':'' %>>Sakit</option>
            </select>
          </div>
          <div class="dp-form-group">
            <label class="dp-form-label">Status Pohon</label>
            <select name="status" class="dp-form-select">
              <option value="hidup"  <%= mon.status==='hidup' ?'selected':'' %>>Hidup</option>
              <option value="mati"   <%= mon.status==='mati'  ?'selected':'' %>>Mati</option>
            </select>
          </div>
          <div class="dp-form-group full">
            <label class="dp-form-label">Deskripsi</label>
            <textarea name="deskripsi" class="dp-form-textarea"><%= mon.deskripsi||'' %></textarea>
          </div>
          <div class="dp-form-group full">
            <label class="dp-form-label">Foto Monitoring <span style="font-weight:300">(opsional)</span></label>
            <input type="file" id="input-foto-mon-<%= tahap %>" name="foto_monitoring"
                   multiple accept="image/*" style="display:none"
                   onchange="handleFoto('mon-<%= tahap %>',this)">
            <button type="button" class="dp-foto-btn"
                    onclick="document.getElementById('input-foto-mon-<%= tahap %>').click()">
              <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="3"/>
                <circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
              </svg>
              Pilih dari File
            </button>
            <div class="dp-foto-preview-grid" id="preview-mon-<%= tahap %>"></div>
            <div class="dp-foto-count"         id="count-mon-<%= tahap %>"></div>
          </div>
        </div>
        <div class="dp-form-actions">
          <button type="button" class="dp-btn-cancel"
                  onclick="toggleSection('mon-<%= tahap %>')">Batal</button>
          <button type="submit" class="dp-btn-save">Simpan Perubahan</button>
        </div>
      </form>

    <% } else if(prevDone){ %>

      <!-- CREATE FORM monitoring -->
      <form id="form-create-<%= tahap %>" class="dp-edit-form"
            action="/petugas-lapangan/monitoring/create"
            method="POST" enctype="multipart/form-data">
        <input type="hidden" name="id_pohon"         value="<%= data.id_pohon %>">
        <input type="hidden" name="tahap_monitoring"  value="<%= tahap %>">
        <div class="dp-form-grid">
          <div class="dp-form-group">
            <label class="dp-form-label">Tanggal Monitoring</label>
            <input type="date" name="tgl_monitoring" class="dp-form-input"
                   value="<%= new Date().toISOString().split('T')[0] %>" required>
          </div>
          <div class="dp-form-group">
            <label class="dp-form-label">Tinggi Pohon (cm)</label>
            <input type="number" step="0.01" name="tinggi_pohon"
                   class="dp-form-input" placeholder="cth: 120" required>
          </div>
          <div class="dp-form-group">
            <label class="dp-form-label">Diameter Batang (cm)</label>
            <input type="number" step="0.01" name="diameter_pohon"
                   class="dp-form-input" placeholder="cth: 5.5" required>
          </div>
          <div class="dp-form-group">
            <label class="dp-form-label">Kesehatan Batang</label>
            <select name="kesehatan_batang" class="dp-form-select" required>
              <option value="" disabled selected>Pilih kondisi</option>
              <option value="baik">Sehat</option>
              <option value="buruk">Sakit</option>
            </select>
          </div>
          <div class="dp-form-group">
            <label class="dp-form-label">Status Pohon</label>
            <select name="status" class="dp-form-select" required>
              <option value="" disabled selected>Pilih status</option>
              <option value="hidup">Hidup</option>
              <option value="mati">Mati</option>
            </select>
          </div>
          <div class="dp-form-group full">
            <label class="dp-form-label">Deskripsi / Catatan</label>
            <textarea name="deskripsi" class="dp-form-textarea"
                      placeholder="Tuliskan catatan kondisi pohon..."></textarea>
          </div>
          <div class="dp-form-group full">
            <label class="dp-form-label">Foto Monitoring <span style="font-weight:300">(wajib min. 1)</span></label>
            <input type="file" id="input-foto-create-<%= tahap %>" name="foto_monitoring"
                   multiple accept="image/*" style="display:none"
                   onchange="handleFoto('create-<%= tahap %>',this)">
            <button type="button" class="dp-foto-btn"
                    onclick="document.getElementById('input-foto-create-<%= tahap %>').click()">
              <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="3"/>
                <circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
              </svg>
              Pilih dari File
            </button>
            <div class="dp-foto-preview-grid" id="preview-create-<%= tahap %>"></div>
            <div class="dp-foto-count"         id="count-create-<%= tahap %>"></div>
          </div>
        </div>
        <div class="dp-form-actions">
          <button type="button" class="dp-btn-cancel"
                  onclick="toggleSection('create-<%= tahap %>')">Batal</button>
          <button type="submit" class="dp-btn-save"
                  onclick="return validateFoto('create-<%= tahap %>')">
            Simpan Monitoring
          </button>
        </div>
      </form>

    <% } %>
  </div>

  <% }) %>

</div>


<script>

  /* ── TOGGLE SECTION ── */
  function toggleSection(key) {
    const formId  = `form-${key}`;
    const viewId  = key.startsWith('create-') ? null : `view-${key}`;
    const btnId   = key.startsWith('create-')
                  ? `btn-create-mon-${key.replace('create-','')}`
                  : `btn-edit-${key}`;

    const form = document.getElementById(formId);
    const view = viewId ? document.getElementById(viewId) : null;
    const btn  = document.getElementById(btnId);
    if (!form) return;

    const isOpen = form.classList.contains('active');
    if (isOpen) {
      form.classList.remove('active');
      if (view) view.style.display = '';
      if (btn)  btn.textContent = key.startsWith('create-') ? 'Update Kondisi' : 'Edit';
    } else {
      form.classList.add('active');
      if (view) view.style.display = 'none';
      if (btn)  btn.textContent = '✕ Tutup';
    }
  }

  /* ── GPS ── */
  function ambilLokasi(evt, key) {
    const btn      = evt.currentTarget;
    const statusEl = document.getElementById(`gps-status-${key}`);
    if (!navigator.geolocation) {
      statusEl.style.color = '#b03030';
      statusEl.textContent = 'Browser tidak mendukung GPS.';
      return;
    }
    btn.disabled = true;
    btn.textContent = '⏳ Mengambil...';
    statusEl.textContent = '';

    navigator.geolocation.getCurrentPosition(
      pos => {
        const lat = pos.coords.latitude.toFixed(6);
        const lng = pos.coords.longitude.toFixed(6);
        const latHidden = document.getElementById(`lat-${key}`);
        const lngHidden = document.getElementById(`lng-${key}`);
        const latShow   = document.getElementById(`show-lat-${key}`);
        const lngShow   = document.getElementById(`show-lng-${key}`);
        if (latHidden) latHidden.value = lat;
        if (lngHidden) lngHidden.value = lng;
        if (latShow)   latShow.value   = lat;
        if (lngShow)   lngShow.value   = lng;
        btn.disabled = false;
        btn.textContent = 'Perbarui Lokasi';
        statusEl.style.color = '#2d6a4f';
        statusEl.textContent = `✓ ${lat}, ${lng} (±${Math.round(pos.coords.accuracy)}m)`;
      },
      err => {
        btn.disabled = false;
        btn.textContent = 'Perbarui Lokasi';
        statusEl.style.color = '#b03030';
        const p = {1:'Izin ditolak.',2:'Lokasi tidak tersedia.',3:'Waktu habis.'};
        statusEl.textContent = p[err.code] || 'Gagal ambil lokasi.';
      },
      { enableHighAccuracy: true, timeout: 10000 }
    );
  }

  /* ── MULTI-FILE FOTO ── */
  const fotoStore = {};

  function handleFoto(key, input) {
    if (!fotoStore[key]) fotoStore[key] = [];
    Array.from(input.files).forEach(f => {
      if (!fotoStore[key].find(e => e.name===f.name && e.size===f.size))
        fotoStore[key].push(f);
    });
    input.value = '';
    syncInput(key);
    renderPreview(key);
  }

  function removeFile(key, idx) {
    fotoStore[key].splice(idx, 1);
    syncInput(key);
    renderPreview(key);
  }

  function syncInput(key) {
    const inputId = key==='penanaman'         ? 'input-foto-penanaman'
                  : key.startsWith('mon-')    ? `input-foto-${key}`
                  : key.startsWith('create-') ? `input-foto-${key}`
                  : null;
    if (!inputId) return;
    const input = document.getElementById(inputId);
    if (!input) return;
    const dt = new DataTransfer();
    (fotoStore[key]||[]).forEach(f => dt.items.add(f));
    input.files = dt.files;
  }

  function renderPreview(key) {
    const grid  = document.getElementById(`preview-${key}`);
    const count = document.getElementById(`count-${key}`);
    if (!grid) return;
    grid.innerHTML = '';
    const files = fotoStore[key] || [];
    if (!files.length) {
      grid.style.display = 'none';
      if (count) count.textContent = '';
      return;
    }
    grid.style.display = 'grid';
    if (count) count.textContent = files.length + ' foto dipilih';
    files.forEach((file, idx) => {
      const reader = new FileReader();
      reader.onload = e => {
        const item = document.createElement('div');
        item.className = 'dp-foto-preview-item';
        item.innerHTML = `
          <img src="${e.target.result}" alt="foto ${idx+1}">
          <button type="button" class="dp-foto-remove"
                  onclick="removeFile('${key}',${idx})">✕</button>`;
        grid.appendChild(item);
      };
      reader.readAsDataURL(file);
    });
  }

  function validateFoto(key) {
    if (!fotoStore[key] || !fotoStore[key].length) {
      alert('Foto monitoring wajib diupload minimal 1 foto');
      return false;
    }
    return true;
  }

</script>
