<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pembayaran — Baby Tree</title>
  <link href="/output.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --green-deep:   #1a4731;
      --green-mid:    #2d6a4f;
      --green-bright: #40916c;
      --green-light:  #74c69d;
      --green-pale:   #d8f3dc;
      --brown-mid:    #7d5a3c;
      --cream:        #fdf8f0;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      background:
        radial-gradient(ellipse 70% 50% at 10% 10%, #b7e4c7 0%, transparent 55%),
        radial-gradient(ellipse 50% 50% at 90% 90%, rgba(201,168,124,.18) 0%, transparent 50%),
        var(--cream);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px 16px;
    }

    /* Leaf deco */
    .leaf { position: fixed; opacity: .1; pointer-events: none; z-index: 0; }
    .leaf-1 { top: -60px; left: -60px; width: 300px; transform: rotate(-20deg); }
    .leaf-2 { bottom: -80px; right: -80px; width: 360px; transform: rotate(160deg); }

    /* Card container */
    .pay-card {
      position: relative; z-index: 10;
      width: 100%; max-width: 480px;
      background: rgba(255,255,255,0.82);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border: 1px solid rgba(116,198,157,.28);
      border-radius: 24px;
      box-shadow: 0 12px 48px rgba(26,71,49,.14), 0 1px 0 rgba(255,255,255,.9) inset;
      overflow: hidden;
      animation: riseUp .6s cubic-bezier(.22,1,.36,1) both;
    }
    @keyframes riseUp {
      from { opacity:0; transform: translateY(24px) scale(.97); }
      to   { opacity:1; transform: translateY(0)    scale(1);   }
    }

    /* Header card */
    .pay-header {
      background: linear-gradient(135deg, var(--green-bright), var(--green-deep));
      padding: 28px 32px 24px;
      display: flex; align-items: center; gap: 14px;
    }
    .pay-header-icon {
      width: 48px; height: 48px; border-radius: 14px;
      background: rgba(255,255,255,.18);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .pay-header-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem; font-weight: 700; color: #fff;
    }
    .pay-header-sub {
      font-size: .8rem; color: rgba(255,255,255,.7); font-weight: 300;
      margin-top: 2px;
    }

    /* Body */
    .pay-body { padding: 28px 32px; }

    /* Section label */
    .sec-label {
      font-size: .68rem; font-weight: 600; letter-spacing: .9px;
      text-transform: uppercase; color: var(--green-bright);
      margin-bottom: 12px;
    }

    /* Info rows */
    .info-list { margin-bottom: 24px; }
    .info-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 11px 0;
      border-bottom: 1px solid rgba(116,198,157,.12);
    }
    .info-row:last-child { border-bottom: none; }
    .info-row-label {
      display: flex; align-items: center; gap: 8px;
      font-size: .84rem; color: var(--brown-mid); font-weight: 400;
    }
    .info-row-label svg { color: var(--green-bright); flex-shrink: 0; }
    .info-row-val {
      font-size: .88rem; font-weight: 500; color: var(--green-deep);
      text-align: right; max-width: 55%;
    }

    /* Status badge */
    .status-badge {
      display: inline-block; padding: 4px 10px; border-radius: 14px;
      font-size: .72rem; font-weight: 600;
    }
    .status-pending  { background: #fff8e1; color: #f57f17; }
    .status-success  { background: #e8f5e9; color: #2d6a4f; }
    .status-failed   { background: #ffebee; color: #b03030; }

    /* Divider */
    .divider {
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(116,198,157,.3), transparent);
      margin: 4px 0 20px;
    }

    /* Total box */
    .total-box {
      background: var(--green-pale);
      border-radius: 14px; padding: 16px 20px;
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 24px;
    }
    .total-box-left { font-size: .82rem; color: var(--green-mid); font-weight: 400; }
    .total-box-amount {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem; font-weight: 700; color: var(--green-deep);
    }

    /* Pay button */
    .btn-pay {
      width: 100%; padding: 14px; border: none; border-radius: 14px;
      background: linear-gradient(135deg, var(--green-bright) 0%, var(--green-deep) 100%);
      color: #fff; font-family: 'DM Sans', sans-serif;
      font-size: 1rem; font-weight: 600; letter-spacing: .3px;
      cursor: pointer;
      box-shadow: 0 6px 20px rgba(45,106,79,.38);
      transition: transform .18s, box-shadow .18s;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      position: relative; overflow: hidden;
    }
    .btn-pay::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,.12), transparent);
    }
    .btn-pay:hover  { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(45,106,79,.48); }
    .btn-pay:active { transform: translateY(0);    box-shadow: 0 4px 12px rgba(45,106,79,.35); }

    /* Loading state */
    .btn-pay.loading { pointer-events: none; opacity: .8; }
    .spinner {
      width: 18px; height: 18px;
      border: 2px solid rgba(255,255,255,.4);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin .7s linear infinite;
      display: none;
    }
    .btn-pay.loading .spinner { display: block; }
    .btn-pay.loading .btn-text { display: none; }
    @keyframes spin { to { transform: rotate(360deg); } }

    .pay-note {
      text-align: center; margin-top: 14px;
      font-size: .75rem; color: #aac8b4; line-height: 1.6;
    }
    .pay-note a { color: var(--green-bright); text-decoration: none; }

    /* Back link */
    .back-link {
      display: flex; align-items: center; gap: 6px;
      font-size: .8rem; color: var(--brown-mid);
      text-decoration: none; margin-bottom: 20px;
      transition: color .18s;
    }
    .back-link:hover { color: var(--green-deep); }
  </style>
</head>
<body>

  <!-- Leaf decorations -->
  <svg class="leaf leaf-1" viewBox="0 0 200 200" fill="none">
    <path d="M100 180 C20 140 10 60 100 20 C190 60 180 140 100 180Z" fill="#2d6a4f"/>
    <line x1="100" y1="20" x2="100" y2="180" stroke="#1a4731" stroke-width="2"/>
    <line x1="100" y1="80"  x2="60"  y2="60"  stroke="#1a4731" stroke-width="1.2"/>
    <line x1="100" y1="110" x2="140" y2="88"  stroke="#1a4731" stroke-width="1.2"/>
  </svg>
  <svg class="leaf leaf-2" viewBox="0 0 200 200" fill="none">
    <path d="M100 180 C20 140 10 60 100 20 C190 60 180 140 100 180Z" fill="#40916c"/>
  </svg>

  <!-- Card -->
  <div style="width:100%; max-width:480px; position:relative; z-index:10">

    <!-- Back -->
    <a href="/" class="back-link">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Kembali ke Beranda
    </a>

    <div class="pay-card">

      <!-- Header -->
      <div class="pay-header">
        <div class="pay-header-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M12 22V12" stroke="#d8f3dc" stroke-width="1.8" stroke-linecap="round"/>
            <path d="M12 12C12 12 8 9 8 5C8 2.5 10 1 12 1C14 1 16 2.5 16 5C16 9 12 12 12 12Z" fill="#74c69d"/>
            <path d="M7 21H17" stroke="#d8f3dc" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <div class="pay-header-title">Konfirmasi Pembayaran</div>
          <div class="pay-header-sub">Selesaikan donasi pohon Anda</div>
        </div>
      </div>

      <!-- Body -->
      <div class="pay-body">

        <!-- Info donatur -->
        <div class="sec-label">Informasi Donatur</div>
        <div class="info-list">
          <div class="info-row">
            <div class="info-row-label">
              <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="8" r="4"/>
                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke-linecap="round"/>
              </svg>
              Nama
            </div>
            <div class="info-row-val"><%= user.nama_lengkap %></div>
          </div>
          <div class="info-row">
            <div class="info-row-label">
              <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="2" y="4" width="20" height="16" rx="3"/>
                <path d="M2 7l10 7 10-7"/>
              </svg>
              Email
            </div>
            <div class="info-row-val"><%= user.email %></div>
          </div>
        </div>

        <div class="divider"></div>

        <!-- Info program -->
        <div class="sec-label">Detail Program</div>
        <div class="info-list">
          <div class="info-row">
            <div class="info-row-label">
              <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M12 22V12" stroke-linecap="round"/>
                <path d="M12 12C12 12 8 9 8 5C8 2.5 10 1 12 1C14 1 16 2.5 16 5C16 9 12 12 12 12Z"/>
              </svg>
              Program
            </div>
            <div class="info-row-val"><%= program.judul_program %></div>
          </div>
          <div class="info-row">
            <div class="info-row-label">
              <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M4 6h16M4 10h16M4 14h10" stroke-linecap="round"/>
              </svg>
              Jumlah Pohon
            </div>
            <div class="info-row-val">
              <strong style="color:var(--green-bright)"><%= donasi.jumlah_pohon.toLocaleString('id-ID') %></strong> pohon
            </div>
          </div>
          <div class="info-row">
            <div class="info-row-label">
              <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 8v4l3 3" stroke-linecap="round"/>
              </svg>
              Status
            </div>
            <div class="info-row-val">
              <%
                const statusCls = payment.status === 'pending' ? 'status-pending'
                                : payment.status === 'success' ? 'status-success'
                                : 'status-failed';
                const statusLabel = payment.status === 'pending' ? 'Menunggu Pembayaran'
                                  : payment.status === 'success' ? 'Berhasil'
                                  : 'Gagal';
              %>
              <span class="status-badge <%= statusCls %>"><%= statusLabel %></span>
            </div>
          </div>
        </div>

        <div class="divider"></div>

        <!-- Total -->
        <div class="total-box">
          <div>
            <div class="total-box-left">Total Pembayaran</div>
            <div style="font-size:.72rem; color:#aac8b4; margin-top:2px">
              <%= donasi.jumlah_pohon %> pohon × Rp <%= Number(program.harga_pohon).toLocaleString('id-ID') %>
            </div>
          </div>
          <div class="total-box-amount">
            Rp <%= Number(payment.gross_amount).toLocaleString('id-ID') %>
          </div>
        </div>

        <!-- Tombol bayar -->
        <button class="btn-pay" id="pay-button">
          <div class="spinner"></div>
          <span class="btn-text" style="display:flex; align-items:center; gap:8px">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="1" y="4" width="22" height="16" rx="2"/>
              <path d="M1 10h22"/>
            </svg>
            Bayar Sekarang
          </span>
        </button>

        <p class="pay-note">
          Pembayaran diproses secara aman melalui Midtrans.<br/>
          Dengan melanjutkan, Anda menyetujui
          <a href="#">syarat & ketentuan</a> donasi Baby Tree.
        </p>

      </div>
    </div>
  </div>

  <!-- Midtrans Snap -->
  <script src="https://app.sandbox.midtrans.com/snap/snap.js"
          data-client-key="<%= clientKey %>"></script>

  <script>
    const payBtn = document.getElementById('pay-button');

    payBtn.addEventListener('click', function () {
      payBtn.classList.add('loading');

      snap.pay('<%= snapToken %>', {
        onSuccess: function(result) {
          console.log('Sukses:', result);
          window.location.href = '/';
        },
        onPending: function(result) {
          console.log('Pending:', result);
          payBtn.classList.remove('loading');
        },
        onError: function(result) {
          console.error('Error:', result);
          payBtn.classList.remove('loading');
        },
        onClose: function() {
          payBtn.classList.remove('loading');
        }
      });
    });
  </script>

</body>
</html>